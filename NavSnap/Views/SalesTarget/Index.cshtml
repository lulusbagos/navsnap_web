@model NavSnap.Models.ViewModels.SalesTargetPageViewModel
@{
    ViewData["Title"] = "Target Harian Sales";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script>document.body.classList.add('pf-page');</script>

<div class="pf-page-header">
    <div class="pf-page-header-left">
        <div class="pf-page-ico"><i class="fas fa-bullseye"></i></div>
        <div>
            <p class="pf-page-title">Pengaturan Target Harian Sales</p>
            <p class="pf-page-sub">Set target toko per hari untuk beberapa sales sekaligus.</p>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-5 mb-4">
        <div class="prem-card">
            <div class="prem-card-head">
                <div class="prem-card-head-ico"><i class="fas fa-sliders-h"></i></div>
                <h6>Set Target Batch</h6>
            </div>
            <div class="prem-card-body">
                <form asp-action="SaveBatch" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" style="background:rgba(239,83,80,.12);border:1px solid rgba(239,83,80,.3);border-radius:10px;padding:10px 14px;font-size:.82rem;color:#ef5350;margin-bottom:16px;"></div>

                    <div class="pf">
                        <label class="pf-lbl">Pilih Sales</label>
                        <div class="prem-checks" style="max-height:220px;overflow-y:auto;">
                            @foreach (var s in Model.SalesList)
                            {
                                var checkedVal = Model.Form.SelectedSalesIds.Contains(s.UserId);
                                <div class="prem-check">
                                    <input type="checkbox" id="sales_@s.UserId" name="SelectedSalesIds" value="@s.UserId" @(checkedVal ? "checked" : "") />
                                    <label for="sales_@s.UserId">
                                        <span class="prem-check-box"></span>
                                        <span>@s.FullName</span>
                                        @if (!s.IsActive)
                                        {
                                            <span class="rbadge rbadge-other ml-1">Nonaktif</span>
                                        }
                                    </label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="pf">
                                <label asp-for="Form.StartDate"></label>
                                <input asp-for="Form.StartDate" type="date" />
                                <span asp-validation-for="Form.StartDate" class="val-err"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="pf">
                                <label asp-for="Form.EndDate"></label>
                                <input asp-for="Form.EndDate" type="date" />
                                <span asp-validation-for="Form.EndDate" class="val-err"></span>
                            </div>
                        </div>
                    </div>

                    <div class="pf">
                        <label asp-for="Form.TargetStores"></label>
                        <input asp-for="Form.TargetStores" type="number" min="1" />
                        <span asp-validation-for="Form.TargetStores" class="val-err"></span>
                        <span class="f-hint">Target yang sama diterapkan ke semua tanggal dalam rentang.</span>
                    </div>

                    <div class="pf">
                        <label asp-for="Form.Notes"></label>
                        <input asp-for="Form.Notes" placeholder="Contoh: Fokus area timur" />
                        <span asp-validation-for="Form.Notes" class="val-err"></span>
                    </div>

                    <button type="submit" class="prem-submit">
                        <i class="fas fa-save"></i>Simpan Target Batch
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-7 mb-4">
        <div class="prem-card">
            <div class="prem-card-head">
                <div class="prem-card-head-ico"><i class="fas fa-calendar-check"></i></div>
                <h6>Daftar Target (H-2 s/d H+21)</h6>
            </div>
            <div class="prem-card-body" style="padding:0;">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th>Tanggal</th>
                                <th>Sales</th>
                                <th>Target</th>
                                <th>Catatan</th>
                                <th width="70">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (!Model.Targets.Any())
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">Belum ada target tersimpan.</td></tr>
                        }
                        @foreach (var t in Model.Targets)
                        {
                            <tr>
                                <td class="small">@t.TargetDate.ToString("dd MMM yyyy")</td>
                                <td>@t.SalesName</td>
                                <td><span class="badge badge-info">@t.TargetStores toko</span></td>
                                <td class="small text-muted">@(string.IsNullOrWhiteSpace(t.Notes) ? "-" : t.Notes)</td>
                                <td>
                                    <form asp-action="Delete" asp-route-id="@t.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Hapus target @t.SalesName pada @t.TargetDate.ToString("dd/MM/yyyy")?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
