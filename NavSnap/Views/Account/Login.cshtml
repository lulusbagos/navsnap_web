@model NavSnap.Models.ViewModels.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Login - NavSnap</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/startbootstrap-sb-admin-2@@4.1.4/vendor/fontawesome-free/css/all.min.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <style>
        :root {
            --bg: #07111f;
            --panel: rgba(9, 20, 36, .88);
            --panel-strong: rgba(12, 28, 48, .96);
            --line: rgba(91, 207, 255, .22);
            --text: #edf7ff;
            --muted: rgba(237, 247, 255, .58);
            --soft: rgba(237, 247, 255, .34);
            --cyan: #3dd8ff;
            --green: #38e8a6;
            --blue: #2176ff;
            --danger: #ff6b6b;
        }

        *, *::before, *::after { box-sizing: border-box; }

        html, body {
            width: 100%;
            min-height: 100%;
            margin: 0;
            font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: var(--bg);
            color: var(--text);
        }

        body {
            min-height: 100vh;
            overflow-x: hidden;
        }

        #radarCanvas {
            position: fixed;
            inset: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            background:
                radial-gradient(circle at 50% 50%, rgba(61, 216, 255, .12), transparent 42%),
                linear-gradient(135deg, #06101d 0%, #081c2d 48%, #07111f 100%);
        }

        .grid {
            position: fixed;
            inset: 0;
            z-index: 1;
            pointer-events: none;
            background-image:
                linear-gradient(rgba(91, 207, 255, .055) 1px, transparent 1px),
                linear-gradient(90deg, rgba(91, 207, 255, .055) 1px, transparent 1px);
            background-size: 42px 42px;
            mask-image: radial-gradient(circle at 50% 50%, black, transparent 78%);
        }

        .login-page {
            position: relative;
            z-index: 2;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 28px;
        }

        .login-shell {
            width: min(960px, 100%);
            min-height: 560px;
            display: grid;
            grid-template-columns: 1.02fr .98fr;
            overflow: hidden;
            border: 1px solid var(--line);
            border-radius: 18px;
            background: rgba(6, 15, 28, .68);
            box-shadow: 0 28px 80px rgba(0, 0, 0, .48);
            backdrop-filter: blur(16px);
        }

        .brand-panel {
            position: relative;
            padding: 48px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            overflow: hidden;
            background:
                radial-gradient(circle at 28% 20%, rgba(61, 216, 255, .20), transparent 34%),
                linear-gradient(145deg, rgba(17, 54, 84, .94), rgba(8, 22, 39, .94));
        }

        .brand-panel::before {
            content: "";
            position: absolute;
            inset: 28px;
            border: 1px solid rgba(61, 216, 255, .18);
            border-radius: 50%;
            opacity: .5;
        }

        .brand-mark {
            position: relative;
            width: 76px;
            height: 76px;
            display: grid;
            place-items: center;
            border-radius: 50%;
            color: white;
            background: linear-gradient(135deg, var(--blue), var(--cyan));
            box-shadow: 0 0 34px rgba(61, 216, 255, .45);
        }

        .brand-mark::before,
        .brand-mark::after {
            content: "";
            position: absolute;
            inset: -14px;
            border: 1px solid rgba(61, 216, 255, .32);
            border-radius: 50%;
            animation: pulseRing 2.8s ease-in-out infinite;
        }

        .brand-mark::after {
            inset: -28px;
            opacity: .45;
            animation-delay: .45s;
        }

        .brand-mark i {
            position: relative;
            font-size: 30px;
        }

        .brand-copy {
            position: relative;
            max-width: 360px;
        }

        .eyebrow {
            margin: 0 0 12px;
            color: var(--green);
            font-size: .72rem;
            font-weight: 800;
            letter-spacing: .16em;
            text-transform: uppercase;
        }

        .brand-copy h1 {
            margin: 0;
            font-size: clamp(2.1rem, 5vw, 3.6rem);
            line-height: .96;
            font-weight: 800;
            letter-spacing: 0;
        }

        .brand-copy p {
            margin: 18px 0 0;
            color: var(--muted);
            font-size: .96rem;
            line-height: 1.7;
        }

        .signal-list {
            position: relative;
            display: grid;
            gap: 10px;
            margin: 36px 0 0;
            padding: 0;
            list-style: none;
        }

        .signal-list li {
            display: flex;
            align-items: center;
            gap: 11px;
            min-height: 42px;
            padding: 10px 12px;
            border: 1px solid rgba(237, 247, 255, .08);
            border-radius: 8px;
            background: rgba(255, 255, 255, .045);
            color: rgba(237, 247, 255, .72);
            font-size: .86rem;
        }

        .signal-list i {
            width: 18px;
            color: var(--cyan);
            text-align: center;
        }

        .form-panel {
            padding: 48px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: var(--panel-strong);
        }

        .status {
            display: inline-flex;
            align-items: center;
            gap: 9px;
            width: fit-content;
            margin-bottom: 28px;
            padding: 7px 10px;
            border: 1px solid rgba(56, 232, 166, .20);
            border-radius: 999px;
            background: rgba(56, 232, 166, .07);
            color: rgba(237, 247, 255, .68);
            font-size: .72rem;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--green);
            box-shadow: 0 0 12px var(--green);
            animation: blink 1.5s ease-in-out infinite;
        }

        .form-title {
            margin-bottom: 28px;
        }

        .form-title h2 {
            margin: 0 0 8px;
            color: var(--text);
            font-size: 1.75rem;
            font-weight: 800;
        }

        .form-title p {
            margin: 0;
            color: var(--muted);
            font-size: .93rem;
            line-height: 1.55;
        }

        .alert-login {
            margin-bottom: 18px;
            padding: 12px 14px;
            border: 1px solid rgba(255, 107, 107, .32);
            border-radius: 8px;
            background: rgba(255, 107, 107, .10);
            color: #ffb8b8;
            font-size: .84rem;
        }

        .field {
            margin-bottom: 18px;
        }

        .field label {
            display: block;
            margin-bottom: 8px;
            color: rgba(237, 247, 255, .62);
            font-size: .74rem;
            font-weight: 800;
            letter-spacing: .09em;
            text-transform: uppercase;
        }

        .field-wrap {
            position: relative;
        }

        .field-wrap i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(61, 216, 255, .62);
            font-size: .9rem;
            pointer-events: none;
        }

        .field-input {
            width: 100%;
            height: 48px;
            padding: 0 14px 0 42px;
            border: 1px solid rgba(91, 207, 255, .18);
            border-radius: 8px;
            outline: 0;
            background: rgba(255, 255, 255, .045);
            color: var(--text);
            font: inherit;
            transition: border-color .2s ease, box-shadow .2s ease, background .2s ease;
        }

        .field-input::placeholder {
            color: rgba(237, 247, 255, .28);
        }

        .field-input:focus {
            border-color: rgba(61, 216, 255, .76);
            background: rgba(61, 216, 255, .075);
            box-shadow: 0 0 0 4px rgba(61, 216, 255, .11);
        }

        .field-error {
            min-height: 18px;
            margin-top: 5px;
            color: var(--danger);
            font-size: .76rem;
        }

        .remember-row {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 2px 0 22px;
            color: var(--muted);
            font-size: .86rem;
        }

        .remember-row input {
            width: 16px;
            height: 16px;
            accent-color: var(--cyan);
        }

        .btn-login {
            width: 100%;
            min-height: 48px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 9px;
            border: 0;
            border-radius: 8px;
            color: #03101b;
            background: linear-gradient(135deg, var(--green), var(--cyan));
            font: inherit;
            font-weight: 800;
            cursor: pointer;
            box-shadow: 0 14px 34px rgba(61, 216, 255, .24);
            transition: transform .18s ease, box-shadow .18s ease, filter .18s ease;
        }

        .btn-login:hover {
            transform: translateY(-1px);
            filter: brightness(1.04);
            box-shadow: 0 18px 42px rgba(61, 216, 255, .34);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .form-footer {
            margin-top: 26px;
            padding-top: 18px;
            border-top: 1px solid rgba(237, 247, 255, .08);
            color: var(--soft);
            font-size: .78rem;
            text-align: center;
        }

        @@keyframes pulseRing {
            0%, 100% { transform: scale(1); opacity: .78; }
            50% { transform: scale(1.08); opacity: .32; }
        }

        @@keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: .28; }
        }

        @@media (max-width: 820px) {
            body { overflow-y: auto; }
            .login-page { padding: 18px; align-items: flex-start; }
            .login-shell { grid-template-columns: 1fr; min-height: auto; }
            .brand-panel { min-height: 280px; padding: 34px 28px; }
            .signal-list { display: none; }
            .form-panel { padding: 34px 28px; }
        }

        @@media (max-width: 460px) {
            .login-page { padding: 12px; }
            .brand-panel, .form-panel { padding: 28px 22px; }
            .brand-mark { width: 64px; height: 64px; }
            .status { font-size: .66rem; }
        }
    </style>
</head>
<body>
    <canvas id="radarCanvas" aria-hidden="true"></canvas>
    <div class="grid" aria-hidden="true"></div>

    <main class="login-page">
        <section class="login-shell" aria-label="Login NavSnap">
            <aside class="brand-panel">
                <div class="brand-mark">
                    <i class="fas fa-location-arrow"></i>
                </div>

                <div class="brand-copy">
                    <p class="eyebrow">Live Tracking Platform</p>
                    <h1>NavSnap</h1>
                    <p>Monitoring sales, checkpoint, dan akses tim dalam satu dashboard yang rapi dan cepat dibaca.</p>

                    <ul class="signal-list">
                        <li><i class="fas fa-satellite-dish"></i>Live GPS Tracking</li>
                        <li><i class="fas fa-map-marked-alt"></i>Checkpoint Management</li>
                        <li><i class="fas fa-user-shield"></i>Role Based Access</li>
                    </ul>
                </div>
            </aside>

            <section class="form-panel">
                <div class="status">
                    <span class="status-dot"></span>
                    <span>System Online</span>
                </div>

                <div class="form-title">
                    <h2>Selamat Datang</h2>
                    <p>Masuk dengan akun yang telah terdaftar untuk mengakses sistem.</p>
                </div>

                <form asp-controller="Account" asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                    @if (ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="alert-login">
                            <i class="fas fa-exclamation-circle"></i>
                            <span asp-validation-summary="ModelOnly"></span>
                        </div>
                    }

                    <div class="field">
                        <label asp-for="Username">Username</label>
                        <div class="field-wrap">
                            <i class="fas fa-user"></i>
                            <input asp-for="Username" class="field-input" placeholder="Masukkan username" autocomplete="username" />
                        </div>
                        <div class="field-error"><span asp-validation-for="Username"></span></div>
                    </div>

                    <div class="field">
                        <label asp-for="Password">Password</label>
                        <div class="field-wrap">
                            <i class="fas fa-lock"></i>
                            <input asp-for="Password" type="password" class="field-input" placeholder="Masukkan password" autocomplete="current-password" />
                        </div>
                        <div class="field-error"><span asp-validation-for="Password"></span></div>
                    </div>

                    <div class="remember-row">
                        <input asp-for="RememberMe" type="checkbox" id="rememberMe" />
                        <label for="rememberMe">Ingat saya di perangkat ini</label>
                    </div>

                    <button type="submit" class="btn-login">
                        <i class="fas fa-sign-in-alt"></i>
                        <span>Masuk ke Sistem</span>
                    </button>
                </form>

                <div class="form-footer">
                    NavSnap HRIS &copy; @DateTime.Now.Year
                </div>
            </section>
        </section>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/startbootstrap-sb-admin-2@@4.1.4/vendor/jquery/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/startbootstrap-sb-admin-2@@4.1.4/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
    <script>
        (function () {
            var canvas = document.getElementById('radarCanvas');
            var ctx = canvas.getContext('2d');
            var width = 0;
            var height = 0;
            var centerX = 0;
            var centerY = 0;
            var radius = 0;
            var sweep = -Math.PI / 2;
            var blips = [];

            function resize() {
                var scale = window.devicePixelRatio || 1;
                width = window.innerWidth;
                height = window.innerHeight;
                canvas.width = Math.floor(width * scale);
                canvas.height = Math.floor(height * scale);
                canvas.style.width = width + 'px';
                canvas.style.height = height + 'px';
                ctx.setTransform(scale, 0, 0, scale, 0, 0);
                centerX = width * .50;
                centerY = height * .50;
                radius = Math.min(width, height) * .44;
                seedBlips();
            }

            function seedBlips() {
                blips = [];
                var count = Math.max(14, Math.floor(Math.min(width, height) / 38));
                for (var i = 0; i < count; i++) {
                    blips.push(makeBlip(Math.random() * Math.PI * 2));
                }
            }

            function makeBlip(angleOffset) {
                var angle = Math.random() * Math.PI * 2;
                var distance = (Math.sqrt(Math.random()) * radius * .9);
                return {
                    x: centerX + Math.cos(angle) * distance,
                    y: centerY + Math.sin(angle) * distance,
                    seenAt: sweep - angleOffset,
                    size: 2 + Math.random() * 2.4
                };
            }

            function drawRings() {
                ctx.save();
                ctx.translate(centerX, centerY);
                ctx.strokeStyle = 'rgba(61,216,255,.22)';
                ctx.lineWidth = 1;

                for (var i = 1; i <= 4; i++) {
                    ctx.beginPath();
                    ctx.arc(0, 0, radius * i / 4, 0, Math.PI * 2);
                    ctx.stroke();
                }

                ctx.setLineDash([6, 8]);
                ctx.strokeStyle = 'rgba(61,216,255,.18)';
                ctx.beginPath();
                ctx.moveTo(-radius, 0);
                ctx.lineTo(radius, 0);
                ctx.moveTo(0, -radius);
                ctx.lineTo(0, radius);
                ctx.stroke();
                ctx.restore();
            }

            function drawSweep() {
                var sweepWidth = Math.PI * .34;
                var steps = 56;

                ctx.save();
                ctx.beginPath();
                ctx.arc(centerX, centerY, radius, 0, Math.PI * 2);
                ctx.clip();

                for (var i = 0; i < steps; i++) {
                    var start = sweep - sweepWidth * i / steps;
                    var end = sweep - sweepWidth * (i + 1) / steps;
                    var alpha = .24 * (1 - i / steps);
                    ctx.beginPath();
                    ctx.moveTo(centerX, centerY);
                    ctx.arc(centerX, centerY, radius, start, end, true);
                    ctx.closePath();
                    ctx.fillStyle = 'rgba(56,232,166,' + alpha.toFixed(3) + ')';
                    ctx.fill();
                }

                ctx.beginPath();
                ctx.moveTo(centerX, centerY);
                ctx.lineTo(centerX + Math.cos(sweep) * radius, centerY + Math.sin(sweep) * radius);
                ctx.strokeStyle = 'rgba(61,216,255,.95)';
                ctx.lineWidth = 2;
                ctx.stroke();
                ctx.restore();
            }

            function drawBlips() {
                for (var i = 0; i < blips.length; i++) {
                    var blip = blips[i];
                    var age = ((sweep - blip.seenAt) % (Math.PI * 2) + Math.PI * 2) % (Math.PI * 2);
                    var alpha = Math.max(0, 1 - age / (Math.PI * 1.5));

                    if (alpha <= .02) {
                        blips[i] = makeBlip(0);
                        continue;
                    }

                    ctx.beginPath();
                    ctx.arc(blip.x, blip.y, blip.size, 0, Math.PI * 2);
                    ctx.fillStyle = 'rgba(56,232,166,' + alpha.toFixed(3) + ')';
                    ctx.fill();

                    ctx.beginPath();
                    ctx.arc(blip.x, blip.y, blip.size * 4, 0, Math.PI * 2);
                    ctx.fillStyle = 'rgba(56,232,166,' + (alpha * .13).toFixed(3) + ')';
                    ctx.fill();
                }
            }

            function draw() {
                ctx.clearRect(0, 0, width, height);

                var glow = ctx.createRadialGradient(centerX, centerY, radius * .08, centerX, centerY, radius * 1.16);
                glow.addColorStop(0, 'rgba(61,216,255,.12)');
                glow.addColorStop(.65, 'rgba(61,216,255,.035)');
                glow.addColorStop(1, 'rgba(61,216,255,0)');
                ctx.fillStyle = glow;
                ctx.fillRect(0, 0, width, height);

                drawRings();
                drawSweep();
                drawBlips();

                ctx.beginPath();
                ctx.arc(centerX, centerY, 4, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(61,216,255,.95)';
                ctx.fill();

                sweep += .018;
                if (sweep > Math.PI * 2) sweep -= Math.PI * 2;
                requestAnimationFrame(draw);
            }

            window.addEventListener('resize', resize);
            resize();
            draw();
        })();
    </script>
</body>
</html>
