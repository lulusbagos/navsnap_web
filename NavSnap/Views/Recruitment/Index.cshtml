@model List<NavSnap.Models.Entities.RecruitmentCandidate>
@{
    ViewData["Title"] = "Rekrutmen";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var activeCount = Model.Count(x => x.Status == "active");
    var hiredCount = Model.Count(x => x.Status == "hired");
    var rejectedCount = Model.Count(x => x.Status == "rejected");
}
<script>document.body.classList.add('pf-page');</script>

<div class="pf-page-header">
    <div class="pf-page-header-left">
        <div class="pf-page-ico"><i class="fas fa-user-plus"></i></div>
        <div><p class="pf-page-title">Rekrutmen</p><p class="pf-page-sub">Pipeline kandidat dari screening sampai offering.</p></div>
    </div>
    <a asp-action="Create" class="pf-back"><i class="fas fa-plus"></i> Tambah Data</a>
</div>

<div class="module-stat-grid">
    <div class="module-stat-card"><div class="module-stat-icon"><i class="fas fa-user-friends"></i></div><div><p class="module-stat-value">@Model.Count</p><p class="module-stat-label">Total Kandidat</p></div></div>
    <div class="module-stat-card"><div class="module-stat-icon"><i class="fas fa-spinner"></i></div><div><p class="module-stat-value">@activeCount</p><p class="module-stat-label">Active</p></div></div>
    <div class="module-stat-card"><div class="module-stat-icon"><i class="fas fa-user-check"></i></div><div><p class="module-stat-value">@hiredCount</p><p class="module-stat-label">Hired</p></div></div>
    <div class="module-stat-card"><div class="module-stat-icon"><i class="fas fa-user-times"></i></div><div><p class="module-stat-value">@rejectedCount</p><p class="module-stat-label">Rejected</p></div></div>
</div>

<div class="card module-card shadow">
    <div class="card-header panel-head d-flex justify-content-between align-items-center"><h6><i class="fas fa-table mr-2"></i>Daftar Kandidat</h6><span class="panel-meta">@Model.Count item</span></div>
    <div class="card-body p-0"><div class="table-responsive"><table class="table table-sm table-hover mb-0">
        <thead class="thead-light"><tr><th>Kandidat</th><th>Kontak</th><th>Posisi</th><th>Stage</th><th>Status</th><th>Source</th><th>Aksi</th></tr></thead>
        <tbody>
        @if (!Model.Any()) { <tr><td colspan="7" class="module-empty">Belum ada data.</td></tr> }
        @foreach (var row in Model)
        {
            <tr>
                <td><strong>@row.CandidateName</strong></td><td class="small">@row.Email<br />@row.Phone</td><td>@row.PositionApplied</td><td><span class="module-chip">@row.Stage</span></td>
                <td>
                    @if (row.Status == "hired")
                    {
                        <span class="badge badge-status-arrived">hired</span>
                    }
                    else if (row.Status == "rejected")
                    {
                        <span class="badge badge-status-skipped">rejected</span>
                    }
                    else if (row.Status == "hold")
                    {
                        <span class="badge badge-status-pending">hold</span>
                    }
                    else
                    {
                        <span class="module-chip">active</span>
                    }
                </td><td>@row.Source</td>
                <td><div class="module-actions"><a asp-action="Edit" asp-route-id="@row.Id" class="btn btn-warning btn-sm"><i class="fas fa-pen"></i></a><form asp-action="Delete" asp-route-id="@row.Id" method="post" class="d-inline" onsubmit="return confirm('Hapus kandidat ini?')">@Html.AntiForgeryToken()<button class="btn btn-danger btn-sm" type="submit"><i class="fas fa-trash"></i></button></form></div></td>
            </tr>
        }
        </tbody>
    </table></div></div>
</div>
