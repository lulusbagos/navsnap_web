@model List<NavSnap.Models.Entities.PayrollAutoSend>
@{
    ViewData["Title"] = "Kirim Payroll Otomatis";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var scheduledCount = Model.Count(x => x.Status == "scheduled");
    var sentCount = Model.Count(x => x.Status == "sent");
    var failedCount = Model.Count(x => x.Status == "failed");
    var recipientTotal = Model.Sum(x => x.RecipientCount);
}
<script>document.body.classList.add('pf-page');</script>

<div class="pf-page-header">
    <div class="pf-page-header-left">
        <div class="pf-page-ico"><i class="fas fa-paper-plane"></i></div>
        <div>
            <p class="pf-page-title">Kirim Payroll Otomatis</p>
            <p class="pf-page-sub">Jadwal pengiriman payroll/slip gaji dan status pengirimannya.</p>
        </div>
    </div>
    <a asp-action="Create" class="pf-back"><i class="fas fa-plus"></i> Tambah Data</a>
</div>

<div class="module-stat-grid">
    <div class="module-stat-card"><div class="module-stat-icon"><i class="fas fa-calendar-check"></i></div><div><p class="module-stat-value">@scheduledCount</p><p class="module-stat-label">Scheduled</p></div></div>
    <div class="module-stat-card"><div class="module-stat-icon"><i class="fas fa-paper-plane"></i></div><div><p class="module-stat-value">@sentCount</p><p class="module-stat-label">Sent</p></div></div>
    <div class="module-stat-card"><div class="module-stat-icon"><i class="fas fa-times-circle"></i></div><div><p class="module-stat-value">@failedCount</p><p class="module-stat-label">Failed</p></div></div>
    <div class="module-stat-card"><div class="module-stat-icon"><i class="fas fa-users"></i></div><div><p class="module-stat-value">@recipientTotal</p><p class="module-stat-label">Recipients</p></div></div>
</div>

<div class="card module-card shadow">
    <div class="card-header panel-head d-flex justify-content-between align-items-center">
        <h6><i class="fas fa-table mr-2"></i>Daftar Jadwal</h6>
        <span class="panel-meta">@Model.Count item</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="thead-light"><tr><th>Periode</th><th>Tanggal Kirim</th><th>Status</th><th>Penerima</th><th>Terkirim</th><th>Catatan</th><th>Aksi</th></tr></thead>
                <tbody>
                @if (!Model.Any()) { <tr><td colspan="7" class="module-empty">Belum ada data.</td></tr> }
                @foreach (var row in Model)
                {
                    <tr>
                        <td>@row.PayrollPeriod</td>
                        <td>@row.SendDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (row.Status == "sent")
                            {
                                <span class="badge badge-status-arrived">sent</span>
                            }
                            else if (row.Status == "failed")
                            {
                                <span class="badge badge-status-skipped">failed</span>
                            }
                            else if (row.Status == "cancelled")
                            {
                                <span class="badge badge-secondary">cancelled</span>
                            }
                            else
                            {
                                <span class="badge badge-status-pending">scheduled</span>
                            }
                        </td>
                        <td>@row.RecipientCount</td>
                        <td>@(row.SentAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                        <td>@row.Notes</td>
                        <td>
                            <div class="module-actions">
                                <a asp-action="Edit" asp-route-id="@row.Id" class="btn btn-warning btn-sm"><i class="fas fa-pen"></i></a>
                                <form asp-action="MarkSent" asp-route-id="@row.Id" method="post" class="d-inline">@Html.AntiForgeryToken()<button class="btn btn-success btn-sm" type="submit" title="Mark Sent"><i class="fas fa-check"></i></button></form>
                                <form asp-action="Delete" asp-route-id="@row.Id" method="post" class="d-inline" onsubmit="return confirm('Hapus jadwal payroll ini?')">@Html.AntiForgeryToken()<button class="btn btn-danger btn-sm" type="submit"><i class="fas fa-trash"></i></button></form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
