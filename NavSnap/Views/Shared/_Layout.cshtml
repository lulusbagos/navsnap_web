@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@inject NavSnap.Data.AppDbContext Db
@{
    var userFullName = User.FindFirstValue("FullName") ?? User.Identity?.Name ?? "User";
    var isApprover = User.IsInRole("Administrator") || User.IsInRole("Pengawas");
    var pendingStore = isApprover ? await Db.StoreSubmissions.CountAsync(x => x.Status == "pending") : 0;
    var pendingLeave = isApprover ? await Db.LeaveRequests.CountAsync(x => x.Status == "pending_supervisor" || x.Status == "pending_hr") : 0;
    var pendingOvertime = isApprover ? await Db.OvertimeRequests.CountAsync(x => x.Status == "pending_supervisor" || x.Status == "pending_hr") : 0;
    var pendingApproval = pendingStore + pendingLeave + pendingOvertime;
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] - NavSnap HRIS</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/startbootstrap-sb-admin-2@4.1.4/vendor/fontawesome-free/css/all.min.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/startbootstrap-sb-admin-2@4.1.4/css/sb-admin-2.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body id="page-top">
    <div id="wrapper">
        <ul class="navbar-nav bg-gradient-primary sidebar sidebar-dark accordion" id="accordionSidebar">
            <a class="sidebar-brand d-flex align-items-center justify-content-center" href="/Home/Index">
                <div class="sidebar-brand-icon">
                    <img src="/img/navsnap.png" alt="NavSnap" class="sidebar-logo-img" />
                </div>
                <div class="sidebar-brand-text mx-3">NavSnap</div>
            </a>
            <hr class="sidebar-divider my-0" />

            @await Component.InvokeAsync("SidebarMenu")

            <div class="text-center d-none d-md-inline mt-3">
                <button class="rounded-circle border-0 btn btn-sm sidebar-toggle-btn" id="sidebarToggle">
                    <i class="fas fa-angle-left"></i>
                </button>
            </div>
            <hr class="sidebar-divider d-none d-md-block" />
        </ul>

        <div id="content-wrapper" class="d-flex flex-column">
            <div id="content">
                <nav class="navbar navbar-expand navbar-light bg-white topbar mb-4 static-top shadow">
                    <button id="sidebarToggleTop" class="btn btn-link d-md-none rounded-circle mr-3">
                        <i class="fa fa-bars"></i>
                    </button>

                    <ul class="navbar-nav ml-auto">
                        @if (isApprover)
                        {
                            <li class="nav-item dropdown no-arrow mx-1">
                                <a class="nav-link dropdown-toggle" href="#" id="alertsDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                    <i class="fas fa-bell fa-fw"></i>
                                    @if (pendingApproval > 0)
                                    {
                                        <span class="badge badge-danger badge-counter">@pendingApproval</span>
                                    }
                                </a>
                                <div class="dropdown-list dropdown-menu dropdown-menu-right shadow animated--grow-in" aria-labelledby="alertsDropdown">
                                    <h6 class="dropdown-header">Notifikasi Approval</h6>
                                    <a class="dropdown-item d-flex align-items-center" href="/Approval/Index">
                                        <div class="mr-3"><div class="icon-circle bg-warning"><i class="fas fa-store text-white"></i></div></div>
                                        <div><div class="small text-gray-500">Pengajuan Toko</div><span class="font-weight-bold">@pendingStore pending</span></div>
                                    </a>
                                    <a class="dropdown-item d-flex align-items-center" href="/Payroll/LeaveOvertime">
                                        <div class="mr-3"><div class="icon-circle bg-info"><i class="fas fa-calendar-minus text-white"></i></div></div>
                                        <div><div class="small text-gray-500">Izin</div><span class="font-weight-bold">@pendingLeave pending</span></div>
                                    </a>
                                    <a class="dropdown-item d-flex align-items-center" href="/Payroll/LeaveOvertime">
                                        <div class="mr-3"><div class="icon-circle bg-primary"><i class="fas fa-business-time text-white"></i></div></div>
                                        <div><div class="small text-gray-500">Lembur</div><span class="font-weight-bold">@pendingOvertime pending</span></div>
                                    </a>
                                    <a class="dropdown-item text-center small text-gray-500" href="/Approval/Index">Buka Approval Center</a>
                                </div>
                            </li>
                        }
                        <div class="topbar-divider d-none d-sm-block"></div>
                        <li class="nav-item dropdown no-arrow">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button"
                               data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <span class="mr-2 d-none d-lg-inline text-gray-600 small">@userFullName</span>
                                <div class="d-inline-block rounded-circle user-avatar-circle">
                                    @(userFullName.Length > 0 ? userFullName[0].ToString().ToUpper() : "U")
                                </div>
                            </a>
                            <div class="dropdown-menu dropdown-menu-right shadow animated--grow-in" aria-labelledby="userDropdown">
                                <a class="dropdown-item" href="#">
                                    <i class="fas fa-user fa-sm fa-fw mr-2 text-gray-400"></i>Profil
                                </a>
                                <div class="dropdown-divider"></div>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item">
                                        <i class="fas fa-sign-out-alt fa-sm fa-fw mr-2 text-gray-400"></i>Keluar
                                    </button>
                                </form>
                            </div>
                        </li>
                    </ul>
                </nav>

                <div class="container-fluid">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle mr-2"></i>@TempData["Success"]
                            <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle mr-2"></i>@TempData["Error"]
                            <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                        </div>
                    }

                    @RenderBody()
                </div>
            </div>

            <footer class="sticky-footer bg-white">
                <div class="container my-auto">
                    <div class="copyright text-center my-auto">
                        <span>NavSnap HRIS &amp; Sales Tracking &copy; @DateTime.Now.Year</span>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <a class="scroll-to-top rounded" href="#page-top">
        <i class="fas fa-angle-up"></i>
    </a>

    <script src="https://cdn.jsdelivr.net/npm/startbootstrap-sb-admin-2@4.1.4/vendor/jquery/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/startbootstrap-sb-admin-2@4.1.4/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/startbootstrap-sb-admin-2@4.1.4/vendor/jquery-easing/jquery.easing.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/startbootstrap-sb-admin-2@4.1.4/js/sb-admin-2.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
