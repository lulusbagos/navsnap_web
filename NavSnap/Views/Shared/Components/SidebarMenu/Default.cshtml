@model List<NavSnap.Models.Entities.Menu>
@{
    var currentUrl = ViewContext.HttpContext.Request.Path.Value ?? "";
    var parents = Model.Where(m => m.ParentId == null).OrderBy(m => m.SortOrder).ThenBy(m => m.Id).ToList();
}

@foreach (var menu in parents)
{
    var children = Model.Where(m => m.ParentId == menu.Id).OrderBy(m => m.SortOrder).ThenBy(m => m.Id).ToList();
    var hasChildren = children.Any();
    var isHeading = string.IsNullOrEmpty(menu.MenuUrl) || menu.MenuUrl == "#";

    if (isHeading)
    {
        <hr class="sidebar-divider my-1" />
        <div class="sidebar-section-heading">@menu.MenuName</div>

        @foreach (var child in children)
        {
            var childActive = currentUrl.StartsWith(child.MenuUrl ?? "~~", StringComparison.OrdinalIgnoreCase);
            <li class="nav-item @(childActive ? "active" : "")">
                <a class="nav-link" href="@child.MenuUrl">
                    <i class="@(child.IconClass ?? "fas fa-circle") fa-fw"></i>
                    <span>@child.MenuName</span>
                </a>
            </li>
        }
        continue;
    }

    if (hasChildren)
    {
        var anyChildActive = children.Any(c => currentUrl.StartsWith(c.MenuUrl ?? "~~", StringComparison.OrdinalIgnoreCase));
        var isActive = anyChildActive || currentUrl.StartsWith(menu.MenuUrl ?? "~~", StringComparison.OrdinalIgnoreCase);
        var collapseId = "collapse_" + menu.Id;
        <li class="nav-item @(isActive ? "active" : "")">
            <a class="nav-link @(isActive ? "" : "collapsed")" href="#" data-toggle="collapse"
               data-target="#@collapseId" aria-expanded="@(isActive ? "true" : "false")" aria-controls="@collapseId">
                <i class="@(menu.IconClass ?? "fas fa-circle") fa-fw"></i>
                <span>@menu.MenuName</span>
            </a>
            <div id="@collapseId" class="collapse @(isActive ? "show" : "")" data-parent="#accordionSidebar">
                <div class="collapse-inner">
                    @foreach (var child in children)
                    {
                        var childActive = currentUrl.StartsWith(child.MenuUrl ?? "~~", StringComparison.OrdinalIgnoreCase);
                        <a class="collapse-item @(childActive ? "active" : "")" href="@child.MenuUrl">
                            <i class="@(child.IconClass ?? "fas fa-angle-right") fa-fw"></i>@child.MenuName
                        </a>
                    }
                </div>
            </div>
        </li>
    }
    else
    {
        var exact = currentUrl.StartsWith(menu.MenuUrl ?? "~~", StringComparison.OrdinalIgnoreCase);
        <li class="nav-item @(exact ? "active" : "")">
            <a class="nav-link" href="@menu.MenuUrl">
                <i class="@(menu.IconClass ?? "fas fa-circle") fa-fw"></i>
                <span>@menu.MenuName</span>
            </a>
        </li>
    }
}

<hr class="sidebar-divider d-none d-md-block" />
