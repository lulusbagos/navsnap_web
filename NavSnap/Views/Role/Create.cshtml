@model NavSnap.Models.ViewModels.RoleViewModel
@{
    bool isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Edit Role" : "Tambah Role";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script>document.body.classList.add('pf-page');</script>

<div class="pf-page-header">
    <div class="pf-page-header-left">
        <div class="pf-page-ico"><i class="fas fa-user-shield"></i></div>
        <div>
            <p class="pf-page-title">@ViewData["Title"]</p>
            <p class="pf-page-sub">@(isEdit ? "Perbarui informasi role" : "Buat role baru untuk mengelola hak akses")</p>
        </div>
    </div>
    <a asp-action="Index" class="pf-back"><i class="fas fa-arrow-left"></i> Kembali</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="prem-card">
            <div class="prem-card-head">
                <div class="prem-card-head-ico"><i class="fas fa-edit"></i></div>
                <h6>Form Role</h6>
            </div>
            <div class="prem-card-body">
                <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.Id)

                    <div class="pf">
                        <label>Nama Role</label>
                        <input asp-for="RoleName" placeholder="Contoh: Supervisor" />
                        <span asp-validation-for="RoleName" class="val-err"></span>
                    </div>

                    <div class="pf">
                        <label>Deskripsi</label>
                        <textarea asp-for="Description" rows="3" placeholder="Deskripsi singkat tentang role ini (opsional)"></textarea>
                    </div>

                    <div class="pf-div"></div>

                    <div class="pf">
                        <label class="pf-lbl">Status</label>
                        <div class="prem-toggle">
                            <input asp-for="IsActive" type="checkbox" class="prem-toggle-input" id="isActive" />
                            <label for="isActive" class="prem-toggle-track"><span class="prem-toggle-thumb"></span></label>
                            <span class="prem-toggle-lbl">Role Aktif</span>
                        </div>
                    </div>

                    <button type="submit" class="prem-submit">
                        <i class="fas fa-save"></i>Simpan Role
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
