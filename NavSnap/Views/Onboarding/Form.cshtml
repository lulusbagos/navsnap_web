@model NavSnap.Models.Entities.OnboardingTask
@{
    var isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Edit Onboarding" : "Tambah Onboarding";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script>document.body.classList.add('pf-page');</script>

<div class="pf-page-header">
    <div class="pf-page-header-left">
        <div class="pf-page-ico"><i class="fas fa-people-arrows"></i></div>
        <div><p class="pf-page-title">@ViewData["Title"]</p><p class="pf-page-sub">Atur task, owner, deadline, dan status onboarding.</p></div>
    </div>
    <a asp-action="Index" class="pf-back"><i class="fas fa-arrow-left"></i> Kembali</a>
</div>

<div class="prem-card module-form-wrap">
    <div class="prem-card-head"><div class="prem-card-head-ico"><i class="fas fa-edit"></i></div><h6>Form Onboarding</h6></div>
    <div class="prem-card-body"><form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()<input asp-for="Id" type="hidden" /><div asp-validation-summary="All" class="text-danger small"></div>
        <div class="pf"><label>Kandidat Terkait</label><select asp-for="CandidateId" asp-items="ViewBag.Candidates"><option value="">- Tidak terkait kandidat -</option></select></div>
        <div class="pf"><label>Nama Employee</label><input asp-for="EmployeeName" maxlength="150" required /></div>
        <div class="pf"><label>Task</label><input asp-for="TaskName" maxlength="150" required /></div>
        <div class="row"><div class="col-md-4"><div class="pf"><label>Due Date</label><input asp-for="DueDate" type="date" /></div></div><div class="col-md-4"><div class="pf"><label>Status</label><select asp-for="Status"><option>open</option><option>in_progress</option><option>done</option><option>blocked</option></select></div></div><div class="col-md-4"><div class="pf"><label>Owner</label><input asp-for="OwnerName" maxlength="100" /></div></div></div>
        <div class="pf"><label>Catatan</label><textarea asp-for="Notes" rows="3" maxlength="500"></textarea></div>
        <button class="prem-submit" type="submit"><i class="fas fa-save"></i>Simpan</button>
    </form></div>
</div>
