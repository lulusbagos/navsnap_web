@model NavSnap.Models.Entities.SalesTargetCompliance
@{
    var isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Edit Compliance Target" : "Tambah Compliance Target";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script>document.body.classList.add('pf-page');</script>

<div class="pf-page-header">
    <div class="pf-page-header-left">
        <div class="pf-page-ico"><i class="fas fa-chart-line"></i></div>
        <div><p class="pf-page-title">@ViewData["Title"]</p><p class="pf-page-sub">Input target dan actual, persentase dihitung otomatis.</p></div>
    </div>
    <a asp-action="Index" class="pf-back"><i class="fas fa-arrow-left"></i> Kembali</a>
</div>

<div class="prem-card module-form-wrap">
    <div class="prem-card-head"><div class="prem-card-head-ico"><i class="fas fa-edit"></i></div><h6>Form Compliance</h6></div>
    <div class="prem-card-body"><form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()<input asp-for="Id" type="hidden" /><div asp-validation-summary="All" class="text-danger small"></div>
        <div class="pf"><label>Sales</label><select asp-for="UserId" asp-items="ViewBag.Users"></select></div>
        <div class="pf"><label>Tanggal Compliance</label><input asp-for="ComplianceDate" type="date" /></div>
        <div class="row"><div class="col-md-6"><div class="pf"><label>Target Kunjungan</label><input asp-for="TargetVisits" type="number" min="0" /></div></div><div class="col-md-6"><div class="pf"><label>Actual Kunjungan</label><input asp-for="ActualVisits" type="number" min="0" /></div></div></div>
        <div class="pf"><label>Catatan</label><textarea asp-for="Notes" rows="3" maxlength="500"></textarea></div>
        <button class="prem-submit" type="submit"><i class="fas fa-save"></i>Simpan</button>
    </form></div>
</div>
