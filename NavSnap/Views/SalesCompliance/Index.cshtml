@model List<NavSnap.Models.Entities.SalesTargetCompliance>
@{
    ViewData["Title"] = "Compliance Target";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var selectedStatus = ViewBag.SelectedStatus as string ?? "";
    var dateFrom = ViewBag.DateFrom as string ?? "";
    var dateTo = ViewBag.DateTo as string ?? "";
    var compliantCount = Model.Count(x => x.Status == "compliant");
    var watchCount = Model.Count(x => x.Status == "watch");
    var riskCount = Model.Count(x => x.Status == "risk");
    var avgCompliance = Model.Any() ? Math.Round(Model.Average(x => x.CompliancePercent), 1) : 0;
}
<script>document.body.classList.add('pf-page');</script>

<div class="pf-page-header">
    <div class="pf-page-header-left">
        <div class="pf-page-ico"><i class="fas fa-chart-line"></i></div>
        <div><p class="pf-page-title">Compliance Target</p><p class="pf-page-sub">Monitoring target vs realisasi kunjungan sales.</p></div>
    </div>
    <a asp-action="Create" class="pf-back"><i class="fas fa-plus"></i> Tambah Data</a>
</div>

<div class="module-stat-grid">
    <div class="module-stat-card"><div class="module-stat-icon"><i class="fas fa-percentage"></i></div><div><p class="module-stat-value">@avgCompliance%</p><p class="module-stat-label">Avg Compliance</p></div></div>
    <div class="module-stat-card"><div class="module-stat-icon"><i class="fas fa-check-circle"></i></div><div><p class="module-stat-value">@compliantCount</p><p class="module-stat-label">Compliant</p></div></div>
    <div class="module-stat-card"><div class="module-stat-icon"><i class="fas fa-eye"></i></div><div><p class="module-stat-value">@watchCount</p><p class="module-stat-label">Watch</p></div></div>
    <div class="module-stat-card"><div class="module-stat-icon"><i class="fas fa-exclamation-triangle"></i></div><div><p class="module-stat-value">@riskCount</p><p class="module-stat-label">Risk</p></div></div>
</div>

<div class="prem-card mb-3">
    <div class="prem-card-head"><div class="prem-card-head-ico"><i class="fas fa-filter"></i></div><h6>Filter Compliance</h6></div>
    <div class="prem-card-body">
        <form method="get" class="row align-items-end">
            <div class="col-md-3"><div class="pf"><label>Sales</label><select name="userId" asp-items="ViewBag.FilterUsers"><option value="">Semua Sales</option></select></div></div>
            <div class="col-md-2"><div class="pf"><label>Status</label><select name="status"><option value="">Semua</option><option value="compliant" selected="@(selectedStatus == "compliant")">compliant</option><option value="watch" selected="@(selectedStatus == "watch")">watch</option><option value="risk" selected="@(selectedStatus == "risk")">risk</option></select></div></div>
            <div class="col-md-2"><div class="pf"><label>Dari</label><input type="date" name="dateFrom" value="@dateFrom" /></div></div>
            <div class="col-md-2"><div class="pf"><label>Sampai</label><input type="date" name="dateTo" value="@dateTo" /></div></div>
            <div class="col-md-3 d-flex mb-3">
                <button type="submit" class="btn btn-primary btn-sm mr-2"><i class="fas fa-search mr-1"></i>Filter</button>
                <a class="btn btn-success btn-sm" asp-action="Export" asp-route-userId="@ViewBag.SelectedUserId" asp-route-status="@selectedStatus" asp-route-dateFrom="@dateFrom" asp-route-dateTo="@dateTo"><i class="fas fa-file-export mr-1"></i>Export CSV</a>
            </div>
        </form>
    </div>
</div>

<div class="card module-card shadow">
    <div class="card-header panel-head d-flex justify-content-between align-items-center"><h6><i class="fas fa-table mr-2"></i>Daftar Compliance</h6><span class="panel-meta">@Model.Count item</span></div>
    <div class="card-body p-0"><div class="table-responsive"><table class="table table-sm table-hover mb-0">
        <thead class="thead-light"><tr><th>Tanggal</th><th>Sales</th><th>Target</th><th>Actual</th><th>Compliance</th><th>Status</th><th>Catatan</th><th>Aksi</th></tr></thead>
        <tbody>
        @if (!Model.Any()) { <tr><td colspan="8" class="module-empty">Belum ada data.</td></tr> }
        @foreach (var row in Model)
        {
            <tr>
                <td>@row.ComplianceDate.ToString("dd/MM/yyyy")</td><td>@(row.User?.FullName ?? "-")</td><td>@row.TargetVisits</td><td>@row.ActualVisits</td><td>@row.CompliancePercent.ToString("0.0")%</td>
                <td>
                    @if (row.Status == "compliant")
                    {
                        <span class="badge badge-status-arrived">compliant</span>
                    }
                    else if (row.Status == "risk")
                    {
                        <span class="badge badge-status-skipped">risk</span>
                    }
                    else
                    {
                        <span class="badge badge-status-pending">watch</span>
                    }
                </td>
                <td class="small text-muted">@row.Notes</td>
                <td><div class="module-actions"><a asp-action="Edit" asp-route-id="@row.Id" class="btn btn-warning btn-sm"><i class="fas fa-pen"></i></a><form asp-action="Delete" asp-route-id="@row.Id" method="post" class="d-inline" onsubmit="return confirm('Hapus compliance report ini?')">@Html.AntiForgeryToken()<button class="btn btn-danger btn-sm" type="submit"><i class="fas fa-trash"></i></button></form></div></td>
            </tr>
        }
        </tbody>
    </table></div></div>
</div>
