@model List<NavSnap.Models.Entities.AuditLog>
@{
    ViewData["Title"] = "Audit Log";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var modules = ViewBag.Modules as List<string> ?? new();
    var selectedModule = ViewBag.SelectedModule as string ?? "";
    var dateFrom = ViewBag.DateFrom as string ?? "";
    var dateTo = ViewBag.DateTo as string ?? "";
}
<script>document.body.classList.add('pf-page');</script>

<div class="pf-page-header">
    <div class="pf-page-header-left">
        <div class="pf-page-ico"><i class="fas fa-clipboard-list"></i></div>
        <div>
            <p class="pf-page-title">Audit Log Aktivitas</p>
            <p class="pf-page-sub">Jejak perubahan data untuk monitoring operasional dan kontrol internal.</p>
        </div>
    </div>
</div>

<div class="prem-card mb-3">
    <div class="prem-card-head"><div class="prem-card-head-ico"><i class="fas fa-filter"></i></div><h6>Filter Audit</h6></div>
    <div class="prem-card-body">
        <form method="get" class="row">
            <div class="col-md-4"><div class="pf"><label>Module</label><select name="module"><option value="">Semua</option>@foreach (var m in modules){<option value="@m" selected="@(selectedModule == m)">@m</option>}</select></div></div>
            <div class="col-md-3"><div class="pf"><label>Dari</label><input type="date" name="dateFrom" value="@dateFrom" /></div></div>
            <div class="col-md-3"><div class="pf"><label>Sampai</label><input type="date" name="dateTo" value="@dateTo" /></div></div>
            <div class="col-md-2 d-flex align-items-end"><button class="btn btn-primary w-100 mb-3" type="submit"><i class="fas fa-search mr-1"></i>Filter</button></div>
        </form>
    </div>
</div>

<div class="card shadow">
    <div class="card-header panel-head d-flex justify-content-between align-items-center">
        <h6><i class="fas fa-history mr-2"></i>Riwayat Aktivitas</h6>
        <span class="panel-meta">@Model.Count item</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="thead-light">
                    <tr><th>Waktu</th><th>User</th><th>Module</th><th>Aksi</th><th>Entity</th><th>Keterangan</th></tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4">Belum ada data audit.</td></tr>
                    }
                    @foreach (var row in Model)
                    {
                        <tr>
                            <td>@row.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                            <td>@(row.User?.FullName ?? "-")</td>
                            <td><span class="badge badge-status-completed">@row.Module</span></td>
                            <td>@row.Action</td>
                            <td>@row.EntityName #@(row.EntityId?.ToString() ?? "-")</td>
                            <td class="small text-muted">@row.Description</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

