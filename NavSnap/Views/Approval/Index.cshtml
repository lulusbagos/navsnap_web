@using NavSnap.Models.Entities
@{
    ViewData["Title"] = "Approval Center";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var submissions = ViewBag.PendingSubmissions as List<StoreSubmission> ?? new();
    var leaves = ViewBag.PendingLeaves as List<LeaveRequest> ?? new();
    var overtimes = ViewBag.PendingOvertimes as List<OvertimeRequest> ?? new();
}
<script>document.body.classList.add('pf-page');</script>

<div class="pf-page-header">
    <div class="pf-page-header-left">
        <div class="pf-page-ico"><i class="fas fa-tasks"></i></div>
        <div>
            <p class="pf-page-title">Approval Center</p>
            <p class="pf-page-sub">Satu pintu approval pengajuan toko, izin, dan lembur.</p>
        </div>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-4 mb-2"><div class="kpi-card"><div class="kpi-title">Pending Pengajuan Toko</div><div class="kpi-val">@submissions.Count</div></div></div>
    <div class="col-md-4 mb-2"><div class="kpi-card"><div class="kpi-title">Pending Izin</div><div class="kpi-val">@leaves.Count</div></div></div>
    <div class="col-md-4 mb-2"><div class="kpi-card"><div class="kpi-title">Pending Lembur</div><div class="kpi-val">@overtimes.Count</div></div></div>
</div>

<div class="card shadow mb-4">
    <div class="card-header panel-head"><h6><i class="fas fa-store mr-2"></i>Pengajuan Toko</h6></div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="thead-light"><tr><th>Sales</th><th>Toko</th><th>Lokasi</th><th>Tgl Kunjungan</th><th>Aksi</th></tr></thead>
                <tbody>
                @if (!submissions.Any()) { <tr><td colspan="5" class="text-center text-muted py-4">Tidak ada pending pengajuan toko.</td></tr> }
                @foreach (var s in submissions)
                {
                    <tr>
                        <td>@s.SalesUser.FullName</td>
                        <td>@s.StoreName</td>
                        <td class="small text-muted">@s.Address</td>
                        <td>@(s.ProposedVisitDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                        <td>
                            <div class="d-flex flex-wrap" style="gap:.35rem;">
                                <form asp-action="ReviewSubmission" method="post" class="d-flex" style="gap:.35rem;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@s.Id" />
                                    <input type="hidden" name="actionType" value="approve" />
                                    <input type="date" name="visitDate" value="@(s.ProposedVisitDate?.ToString("yyyy-MM-dd") ?? DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd"))" class="form-control form-control-sm" style="max-width:150px;" />
                                    <button class="btn btn-sm btn-outline-success" type="submit"><i class="fas fa-check mr-1"></i>Approve</button>
                                </form>
                                <form asp-action="ReviewSubmission" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@s.Id" />
                                    <input type="hidden" name="actionType" value="reject" />
                                    <button class="btn btn-sm btn-outline-danger" type="submit"><i class="fas fa-times mr-1"></i>Reject</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-6 mb-4">
        <div class="card shadow">
            <div class="card-header panel-head"><h6><i class="fas fa-calendar-minus mr-2"></i>Pending Izin</h6></div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="thead-light"><tr><th>Nama</th><th>Periode</th><th>Tipe</th><th>Tahap</th><th>Aksi</th></tr></thead>
                        <tbody>
                        @if (!leaves.Any()) { <tr><td colspan="5" class="text-center text-muted py-4">Tidak ada pending izin.</td></tr> }
                        @foreach (var l in leaves)
                        {
                            <tr>
                                <td>@l.User.FullName</td>
                                <td>@l.LeaveDateFrom.ToString("dd/MM") - @l.LeaveDateTo.ToString("dd/MM")</td>
                                <td>@l.LeaveType</td>
                                <td>Tahap @l.ApprovalStage</td>
                                <td><a class="btn btn-sm btn-primary" href="/Payroll/LeaveOvertime">Proses</a></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6 mb-4">
        <div class="card shadow">
            <div class="card-header panel-head"><h6><i class="fas fa-business-time mr-2"></i>Pending Lembur</h6></div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="thead-light"><tr><th>Nama</th><th>Tanggal</th><th>Jam</th><th>Tahap</th><th>Aksi</th></tr></thead>
                        <tbody>
                        @if (!overtimes.Any()) { <tr><td colspan="5" class="text-center text-muted py-4">Tidak ada pending lembur.</td></tr> }
                        @foreach (var o in overtimes)
                        {
                            <tr>
                                <td>@o.User.FullName</td>
                                <td>@o.OvertimeDate.ToString("dd/MM/yyyy")</td>
                                <td>@o.Hours</td>
                                <td>Tahap @o.ApprovalStage</td>
                                <td><a class="btn btn-sm btn-primary" href="/Payroll/LeaveOvertime">Proses</a></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

