@model List<NavSnap.Models.Entities.SalesVisitReport>
@{
    ViewData["Title"] = "Laporan Kunjungan";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var selectedStatus = ViewBag.SelectedStatus as string ?? "";
    var dateFrom = ViewBag.DateFrom as string ?? "";
    var dateTo = ViewBag.DateTo as string ?? "";
    var completedCount = Model.Count(x => x.VisitStatus == "completed");
    var arrivedCount = Model.Count(x => x.VisitStatus == "arrived");
    var pendingCount = Model.Count(x => x.VisitStatus == "pending");
}
<script>document.body.classList.add('pf-page');</script>

<div class="pf-page-header">
    <div class="pf-page-header-left">
        <div class="pf-page-ico"><i class="fas fa-clipboard-check"></i></div>
        <div>
            <p class="pf-page-title">Laporan Kunjungan</p>
            <p class="pf-page-sub">Hasil kunjungan sales ke checkpoint, outcome, dan catatan follow-up.</p>
        </div>
    </div>
    <a asp-action="Create" class="pf-back"><i class="fas fa-plus"></i> Tambah Data</a>
</div>

<div class="module-stat-grid">
    <div class="module-stat-card"><div class="module-stat-icon"><i class="fas fa-clipboard-list"></i></div><div><p class="module-stat-value">@Model.Count</p><p class="module-stat-label">Total Laporan</p></div></div>
    <div class="module-stat-card"><div class="module-stat-icon"><i class="fas fa-check-circle"></i></div><div><p class="module-stat-value">@completedCount</p><p class="module-stat-label">Completed</p></div></div>
    <div class="module-stat-card"><div class="module-stat-icon"><i class="fas fa-map-marker-alt"></i></div><div><p class="module-stat-value">@arrivedCount</p><p class="module-stat-label">Arrived</p></div></div>
    <div class="module-stat-card"><div class="module-stat-icon"><i class="fas fa-clock"></i></div><div><p class="module-stat-value">@pendingCount</p><p class="module-stat-label">Pending</p></div></div>
</div>

<div class="prem-card mb-3">
    <div class="prem-card-head"><div class="prem-card-head-ico"><i class="fas fa-filter"></i></div><h6>Filter Laporan</h6></div>
    <div class="prem-card-body">
        <form method="get" class="row align-items-end">
            <div class="col-md-3"><div class="pf"><label>Sales</label><select name="userId" asp-items="ViewBag.FilterUsers"><option value="">Semua Sales</option></select></div></div>
            <div class="col-md-2"><div class="pf"><label>Status</label><select name="status"><option value="">Semua</option><option value="completed" selected="@(selectedStatus == "completed")">completed</option><option value="arrived" selected="@(selectedStatus == "arrived")">arrived</option><option value="pending" selected="@(selectedStatus == "pending")">pending</option><option value="skipped" selected="@(selectedStatus == "skipped")">skipped</option></select></div></div>
            <div class="col-md-2"><div class="pf"><label>Dari</label><input type="date" name="dateFrom" value="@dateFrom" /></div></div>
            <div class="col-md-2"><div class="pf"><label>Sampai</label><input type="date" name="dateTo" value="@dateTo" /></div></div>
            <div class="col-md-3 d-flex mb-3">
                <button type="submit" class="btn btn-primary btn-sm mr-2"><i class="fas fa-search mr-1"></i>Filter</button>
                <a class="btn btn-success btn-sm" asp-action="Export" asp-route-userId="@ViewBag.SelectedUserId" asp-route-status="@selectedStatus" asp-route-dateFrom="@dateFrom" asp-route-dateTo="@dateTo"><i class="fas fa-file-export mr-1"></i>Export CSV</a>
            </div>
        </form>
    </div>
</div>

<div class="card module-card shadow">
    <div class="card-header panel-head d-flex justify-content-between align-items-center">
        <h6><i class="fas fa-table mr-2"></i>Daftar Laporan</h6>
        <span class="panel-meta">@Model.Count item</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="thead-light"><tr><th>Tanggal</th><th>Sales</th><th>Checkpoint</th><th>Status</th><th>Outcome</th><th>Catatan</th><th>Aksi</th></tr></thead>
                <tbody>
                    @if (!Model.Any()) { <tr><td colspan="7" class="text-center text-muted py-4">Belum ada data.</td></tr> }
                    @foreach (var row in Model)
                    {
                        <tr>
                            <td>@row.ReportDate.ToString("dd/MM/yyyy")</td>
                            <td>@(row.User?.FullName ?? "-")</td>
                            <td>@(row.Checkpoint?.CheckpointName ?? "-")</td>
                            <td><span class="module-chip">@row.VisitStatus</span></td>
                            <td>@row.Outcome</td>
                            <td class="small text-muted">@row.Notes</td>
                            <td><div class="module-actions">
                                <a asp-action="Edit" asp-route-id="@row.Id" class="btn btn-warning btn-sm"><i class="fas fa-pen"></i></a>
                                <form asp-action="Delete" asp-route-id="@row.Id" method="post" class="d-inline" onsubmit="return confirm('Hapus report ini?')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-danger btn-sm" type="submit"><i class="fas fa-trash"></i></button>
                                </form>
                            </div></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
