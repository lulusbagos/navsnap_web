@{
    ViewData["Title"] = "Live Sales Tracking";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script>document.body.classList.add('page-tracking');</script>

@section Styles {
<style>
    /* ── layout reset ── */
    #content { padding: 0 !important; }
    .container-fluid { padding: 0 !important; }

    /* ════════════════════════════════════════════════════════
       THEME VARIABLES
    ════════════════════════════════════════════════════════ */
    :root {
        --bg-deep:    #060d1a;
        --bg-panel:   #080f1e;
        --bg-card:    rgba(255,255,255,0.03);
        --bg-card-hv: rgba(56,189,248,0.08);
        --border:     rgba(56,189,248,0.12);
        --border-hv:  rgba(56,189,248,0.3);
        --accent:     #38bdf8;
        --accent2:    #818cf8;
        --accent3:    #34d399;
        --accent-warn:#fbbf24;
        --text-main:  #e0f2fe;
        --text-muted: rgba(255,255,255,0.35);
        --text-dim:   rgba(255,255,255,0.18);
        --glow-blue:  rgba(56,189,248,0.45);
        --glow-green: rgba(52,211,153,0.5);
        --panel-w:    330px;
    }
    body.theme-purple {
        --bg-deep:    #0d0820;
        --bg-panel:   #110b24;
        --bg-card:    rgba(255,255,255,0.03);
        --bg-card-hv: rgba(129,140,248,0.08);
        --border:     rgba(129,140,248,0.15);
        --border-hv:  rgba(129,140,248,0.4);
        --accent:     #818cf8;
        --accent2:    #f472b6;
        --accent3:    #34d399;
        --accent-warn:#fbbf24;
        --glow-blue:  rgba(129,140,248,0.5);
    }
    body.theme-green {
        --bg-deep:    #031309;
        --bg-panel:   #041510;
        --bg-card:    rgba(255,255,255,0.03);
        --bg-card-hv: rgba(52,211,153,0.08);
        --border:     rgba(52,211,153,0.15);
        --border-hv:  rgba(52,211,153,0.35);
        --accent:     #34d399;
        --accent2:    #38bdf8;
        --accent3:    #fbbf24;
        --accent-warn:#f472b6;
        --glow-blue:  rgba(52,211,153,0.45);
    }

    /* ════════════════════════════════════════════════════════
       WRAPPER
    ════════════════════════════════════════════════════════ */
    .tracking-wrap {
        position: relative;
        width: 100%;
        height: calc(100vh - 70px);
        display: flex;
        background: var(--bg-deep);
        overflow: hidden;
    }

    /* ── map ── */
    #liveMap { flex: 1; height: 100%; z-index: 1; }

    /* ════════════════════════════════════════════════════════
       FLOATING TOP BAR
    ════════════════════════════════════════════════════════ */
    .map-topbar {
        position: absolute;
        top: 14px; left: 14px; right: calc(var(--panel-w) + 14px);
        z-index: 500;
        display: flex; align-items: center; justify-content: space-between;
        pointer-events: none;
    }
    .map-title-badge {
        display: flex; align-items: center; gap: 12px;
        background: rgba(6,13,26,0.88);
        border: 1px solid var(--border-hv);
        border-radius: 12px;
        padding: 10px 18px;
        backdrop-filter: blur(14px);
        box-shadow: 0 4px 24px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.03);
        pointer-events: auto;
    }
    .live-pulse {
        position: relative; width: 10px; height: 10px; flex-shrink: 0;
    }
    .live-pulse::before, .live-pulse::after {
        content: ''; position: absolute; inset: 0; border-radius: 50%;
    }
    .live-pulse::before { background: var(--accent3); }
    .live-pulse::after {
        background: transparent;
        border: 2px solid var(--accent3);
        animation: lp 1.6s ease-out infinite;
    }
    @@keyframes lp { 0%{transform:scale(1);opacity:.8} 100%{transform:scale(2.8);opacity:0} }

    .map-title-badge .t-title {
        font-size: .9rem; font-weight: 800; color: #fff; letter-spacing: .3px; margin: 0;
        line-height: 1.2;
    }
    .map-title-badge .t-sub {
        font-size: .68rem; color: var(--text-muted); letter-spacing: .4px;
    }

    /* meta chips */
    .map-meta { display: flex; gap: 8px; pointer-events: auto; }
    .meta-chip {
        background: rgba(6,13,26,0.88);
        border: 1px solid var(--border);
        border-radius: 8px; padding: 6px 13px;
        backdrop-filter: blur(14px);
        font-size: .73rem; color: var(--text-muted);
        display: flex; align-items: center; gap: 7px;
        transition: border-color .2s, color .2s;
    }
    .meta-chip i { color: var(--accent); }
    .meta-chip:hover { border-color: var(--border-hv); color: var(--text-main); }

    /* theme switcher */
    .theme-switcher {
        display: flex; gap: 6px;
        background: rgba(6,13,26,0.88);
        border: 1px solid var(--border);
        border-radius: 8px; padding: 5px 8px;
        backdrop-filter: blur(14px);
        pointer-events: auto;
    }
    .theme-btn {
        width: 20px; height: 20px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.2);
        cursor: pointer; transition: transform .15s, border-color .15s;
        outline: none;
    }
    .theme-btn:hover { transform: scale(1.2); border-color: rgba(255,255,255,0.6); }
    .theme-btn.active { border-color: #fff; transform: scale(1.15); }

    /* ════════════════════════════════════════════════════════
       LEGEND
    ════════════════════════════════════════════════════════ */
    .map-legend {
        position: absolute;
        bottom: 14px; left: 14px;
        z-index: 500;
        background: rgba(6,13,26,0.88);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 8px 16px;
        backdrop-filter: blur(14px);
        display: flex; gap: 18px; align-items: center;
    }
    .legend-label {
        font-size: .65rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
        color: var(--text-dim); margin-right: 4px;
    }
    .legend-item { display: flex; align-items: center; gap: 7px; }
    .leg-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .legend-item span { font-size: .72rem; color: var(--text-muted); }

    /* ════════════════════════════════════════════════════════
       SIDE PANEL
    ════════════════════════════════════════════════════════ */
    .side-panel {
        width: var(--panel-w);
        flex-shrink: 0; height: 100%;
        background: var(--bg-panel);
        border-left: 1px solid var(--border);
        display: flex; flex-direction: column;
        z-index: 100; overflow: hidden;
    }

    /* panel header */
    .side-header {
        padding: 14px 18px 10px;
        background: linear-gradient(180deg, rgba(0,0,0,0.4) 0%, transparent 100%);
        border-bottom: 1px solid var(--border);
        flex-shrink: 0;
    }
    .side-header-top {
        display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;
    }
    .side-header-top h6 {
        margin: 0; font-size: .8rem; font-weight: 800;
        letter-spacing: 1.2px; text-transform: uppercase;
        color: var(--text-muted);
    }
    .side-header-top h6 i { color: var(--accent); }
    .header-refresh-btn {
        background: none; border: 1px solid var(--border); border-radius: 6px;
        color: var(--accent); padding: 3px 8px; font-size: .7rem; cursor: pointer;
        transition: background .15s;
    }
    .header-refresh-btn:hover { background: var(--bg-card-hv); }

    /* stat row */
    .stat-row {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px;
    }
    .stat-box {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 8px; padding: 8px 10px; text-align: center;
    }
    .stat-box .s-val {
        font-size: 1.1rem; font-weight: 800; color: var(--text-main); line-height: 1;
    }
    .stat-box .s-lbl {
        font-size: .62rem; color: var(--text-muted); margin-top: 3px;
        text-transform: uppercase; letter-spacing: .8px;
    }

    /* tab nav */
    .tab-nav {
        display: flex; border-bottom: 1px solid var(--border);
        flex-shrink: 0;
    }
    .tab-btn {
        flex: 1; padding: 9px 0; font-size: .72rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .8px;
        color: var(--text-muted); background: none; border: none; cursor: pointer;
        border-bottom: 2px solid transparent; transition: color .15s, border-color .15s;
        display: flex; align-items: center; justify-content: center; gap: 6px;
    }
    .tab-btn i { font-size: .75rem; }
    .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }
    .tab-btn:hover:not(.active) { color: var(--text-main); }

    /* tab content */
    .tab-pane { display: none; }
    .tab-pane.active { display: block; }
    .panel-scroll {
        flex: 1; overflow-y: auto; min-height: 0;
    }
    .panel-scroll::-webkit-scrollbar { width: 3px; }
    .panel-scroll::-webkit-scrollbar-track { background: transparent; }
    .panel-scroll::-webkit-scrollbar-thumb {
        background: var(--border-hv); border-radius: 2px;
    }

    /* section label */
    .section-label {
        padding: 12px 16px 5px;
        font-size: .65rem; font-weight: 800;
        letter-spacing: 1.5px; text-transform: uppercase;
        color: var(--accent); opacity: .7;
        display: flex; align-items: center; gap: 8px;
    }
    .section-label::after {
        content: ''; flex: 1; height: 1px; background: var(--border);
    }

    /* sales card */
    .sales-card {
        margin: 5px 12px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 10px; padding: 10px 13px;
        display: flex; align-items: center; gap: 11px;
        transition: background .15s, border-color .15s, transform .12s;
        cursor: pointer;
    }
    .sales-card:hover {
        background: var(--bg-card-hv);
        border-color: var(--border-hv);
        transform: translateX(2px);
    }
    .sales-avatar {
        width: 36px; height: 36px; border-radius: 50%;
        background: linear-gradient(135deg, var(--accent2), var(--accent));
        display: flex; align-items: center; justify-content: center;
        font-size: 13px; font-weight: 800; color: #fff; flex-shrink: 0;
        box-shadow: 0 0 14px var(--glow-blue);
    }
    .sales-info { flex: 1; min-width: 0; }
    .s-name {
        font-size: .82rem; font-weight: 700; color: var(--text-main);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .s-meta {
        font-size: .68rem; color: var(--text-muted); margin-top: 2px;
        display: flex; align-items: center; gap: 4px;
    }
    .s-meta i { color: var(--accent); opacity: .7; }
    .online-pill {
        font-size: .62rem; font-weight: 700;
        background: rgba(52,211,153,0.12);
        color: var(--accent3);
        border: 1px solid rgba(52,211,153,0.3);
        border-radius: 20px; padding: 2px 8px; white-space: nowrap;
        display: flex; align-items: center; gap: 4px;
    }
    .online-pill::before {
        content: ''; width: 5px; height: 5px; border-radius: 50%;
        background: var(--accent3);
        box-shadow: 0 0 6px var(--glow-green);
    }

    /* checkpoint card */
    .cp-card {
        margin: 5px 12px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 10px; padding: 10px 13px;
        display: flex; align-items: center; justify-content: space-between; gap: 10px;
        transition: background .15s, border-color .15s, transform .12s;
        cursor: pointer;
    }
    .cp-card:hover {
        background: var(--bg-card-hv);
        border-color: var(--border-hv);
        transform: translateX(2px);
    }
    .cp-icon-wrap {
        width: 30px; height: 30px; border-radius: 8px; flex-shrink: 0;
        background: rgba(56,189,248,0.1);
        border: 1px solid var(--border);
        display: flex; align-items: center; justify-content: center;
    }
    .cp-icon-wrap i { font-size: .75rem; color: var(--accent); }
    .cp-name {
        font-size: .8rem; font-weight: 600; color: #cfd8dc;
        flex: 1; min-width: 0;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .status-badge {
        font-size: .62rem; font-weight: 700;
        border-radius: 20px; padding: 2px 9px;
        white-space: nowrap; flex-shrink: 0;
    }
    .sb-arrived { background: rgba(52,211,153,0.12); color: var(--accent3); border: 1px solid rgba(52,211,153,0.3); }
    .sb-pending  { background: rgba(251,191,36,0.12); color: var(--accent-warn); border: 1px solid rgba(251,191,36,0.3); }
    .sb-none     { background: rgba(255,255,255,0.04); color: var(--text-dim); border: 1px solid var(--border); }

    /* empty state */
    .empty-state {
        padding: 32px 18px; text-align: center;
        font-size: .8rem; color: var(--text-dim);
    }
    .empty-state i { font-size: 1.8rem; margin-bottom: 10px; display: block; opacity: .25; }

    /* panel footer */
    .side-footer {
        padding: 9px 16px;
        border-top: 1px solid var(--border);
        font-size: .68rem; color: var(--text-dim);
        display: flex; align-items: center; justify-content: space-between;
        flex-shrink: 0;
        background: rgba(0,0,0,0.2);
    }
    .side-footer i { color: var(--accent); opacity: .6; }
    .count-badge {
        font-size: .7rem; font-weight: 700;
        color: var(--accent); background: rgba(56,189,248,0.1);
        border: 1px solid var(--border); border-radius: 20px;
        padding: 1px 9px;
    }

    /* ════════════════════════════════════════════════════════
       LEAFLET OVERRIDES
    ════════════════════════════════════════════════════════ */
    .leaflet-popup-content-wrapper {
        background: #0a1525 !important;
        border: 1px solid var(--border-hv) !important;
        border-radius: 12px !important;
        box-shadow: 0 8px 30px rgba(0,0,0,0.7), 0 0 0 1px rgba(255,255,255,0.03) !important;
        color: var(--text-main) !important;
    }
    .leaflet-popup-tip { background: #0a1525 !important; }
    .leaflet-popup-content { margin: 12px 16px !important; font-size: .82rem !important; line-height: 1.5 !important; }
    .leaflet-popup-content strong { color: #fff; font-size: .88rem; }
    .leaflet-popup-close-button { color: var(--text-muted) !important; font-size: 18px !important; top: 6px !important; right: 8px !important; }
    .leaflet-popup-close-button:hover { color: #fff !important; }
    .leaflet-control-zoom a {
        background: rgba(6,13,26,0.9) !important;
        border-color: var(--border) !important;
        color: var(--accent) !important;
    }
    .leaflet-control-zoom a:hover { background: var(--bg-card-hv) !important; }
    .leaflet-control-attribution {
        background: rgba(6,13,26,0.7) !important;
        color: var(--text-dim) !important; font-size: 10px !important;
    }
    .leaflet-control-attribution a { color: var(--accent) !important; opacity: .6; }
</style>
}

<div class="tracking-wrap">

    <!-- ── Map ──────────────────────────────────────────────── -->
    <div id="liveMap"></div>

    <!-- ── Floating top bar ─────────────────────────────────── -->
    <div class="map-topbar">
        <div class="map-title-badge">
            <div class="live-pulse"></div>
            <div>
                <p class="t-title"><i class="fas fa-satellite-dish mr-2" style="color:var(--accent);"></i>Live Sales Tracking</p>
                <p class="t-sub">Auto-refresh setiap 15 detik</p>
            </div>
        </div>
        <div class="d-flex align-items-center gap-2" style="gap:8px;">
            <div class="map-meta">
                <div class="meta-chip"><i class="fas fa-user-circle"></i>Sales</div>
                <div class="meta-chip"><i class="fas fa-map-pin"></i>Checkpoint</div>
                <div class="meta-chip" id="lastRefreshChip"><i class="fas fa-sync-alt"></i><span id="lastRefreshLabel">—</span></div>
            </div>
            <!-- Theme switcher -->
            <div class="theme-switcher" title="Ganti tema">
                <button class="theme-btn active" style="background:linear-gradient(135deg,#060d1a,#38bdf8);" data-theme="default" onclick="setTheme(this,'default')" title="Biru Gelap"></button>
                <button class="theme-btn" style="background:linear-gradient(135deg,#0d0820,#818cf8);" data-theme="purple" onclick="setTheme(this,'purple')" title="Ungu"></button>
                <button class="theme-btn" style="background:linear-gradient(135deg,#031309,#34d399);" data-theme="green" onclick="setTheme(this,'green')" title="Hijau"></button>
            </div>
        </div>
    </div>

    <!-- ── Legend ───────────────────────────────────────────── -->
    <div class="map-legend">
        <span class="legend-label">Legenda</span>
        <div class="legend-item"><div class="leg-dot" style="background:var(--accent);box-shadow:0 0 8px var(--glow-blue);"></div><span>Sales Online</span></div>
        <div class="legend-item"><div class="leg-dot" style="background:var(--accent3);box-shadow:0 0 8px var(--glow-green);"></div><span>Sudah Tiba</span></div>
        <div class="legend-item"><div class="leg-dot" style="background:#fbbf24;"></div><span>Pending</span></div>
        <div class="legend-item"><div class="leg-dot" style="background:#546e7a;"></div><span>Belum Ditugaskan</span></div>
    </div>

    <!-- ── Right panel ──────────────────────────────────────── -->
    <div class="side-panel">

        <!-- header -->
        <div class="side-header">
            <div class="side-header-top">
                <h6><i class="fas fa-broadcast-tower mr-2"></i>Panel Monitoring</h6>
                <button class="header-refresh-btn" onclick="updateTracking()" title="Refresh sekarang">
                    <i class="fas fa-sync-alt mr-1"></i>Refresh
                </button>
            </div>
            <div class="stat-row">
                <div class="stat-box">
                    <div class="s-val" id="statOnline">—</div>
                    <div class="s-lbl">Online</div>
                </div>
                <div class="stat-box">
                    <div class="s-val" id="statArrived" style="color:var(--accent3);">—</div>
                    <div class="s-lbl">Tiba</div>
                </div>
                <div class="stat-box">
                    <div class="s-val" id="statPending" style="color:var(--accent-warn);">—</div>
                    <div class="s-lbl">Pending</div>
                </div>
            </div>
        </div>

        <!-- tabs -->
        <div class="tab-nav">
            <button class="tab-btn active" onclick="switchTab('tab-sales',this)">
                <i class="fas fa-users"></i>Sales
            </button>
            <button class="tab-btn" onclick="switchTab('tab-cp',this)">
                <i class="fas fa-map-pin"></i>Checkpoint
            </button>
        </div>

        <!-- scrollable content -->
        <div class="panel-scroll">
            <!-- Sales tab -->
            <div id="tab-sales" class="tab-pane active">
                <div class="section-label"><i class="fas fa-circle" style="font-size:.5rem;"></i>Posisi Real-time</div>
                <div id="salesList">
                    <div class="empty-state"><i class="fas fa-satellite-dish"></i>Memuat data sales...</div>
                </div>
            </div>
            <!-- Checkpoint tab -->
            <div id="tab-cp" class="tab-pane">
                <div class="section-label"><i class="fas fa-circle" style="font-size:.5rem;"></i>Status Hari Ini</div>
                <div id="cpStatusList">
                    <div class="empty-state"><i class="fas fa-map-marker-alt"></i>Memuat checkpoint...</div>
                </div>
            </div>
        </div>

        <!-- footer -->
        <div class="side-footer">
            <span><i class="fas fa-clock mr-1"></i>Update: <span id="sideLastUpdate">—</span></span>
            <span id="countBadge" class="count-badge"></span>
        </div>
    </div>

</div>

@section Scripts {
<script>
    /* ── Theme switcher ─────────────────────────────────────── */
    function setTheme(btn, theme) {
        document.querySelectorAll('.theme-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.body.classList.remove('theme-purple','theme-green');
        if (theme !== 'default') document.body.classList.add('theme-' + theme);
        // update tile layer
        updateTileTheme(theme);
    }
    var tileLayer;
    function updateTileTheme(theme) {
        if (tileLayer) map.removeLayer(tileLayer);
        var url, attr;
        if (theme === 'green') {
            url  = 'https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png';
        } else if (theme === 'purple') {
            url  = 'https://tiles.stadiamaps.com/tiles/alidade_smooth_dark/{z}/{x}/{y}{r}.png';
        } else {
            url  = 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png';
        }
        attr = '&copy; <a href="https://carto.com/">CARTO</a> &copy; <a href="https://www.openstreetmap.org/copyright">OSM</a>';
        tileLayer = L.tileLayer(url, { attribution: attr, subdomains: 'abcd', maxZoom: 19 });
        tileLayer.addTo(map);
    }

    /* ── Tab switching ──────────────────────────────────────── */
    function switchTab(id, btn) {
        document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById(id).classList.add('active');
        btn.classList.add('active');
    }

    /* ── Init map ───────────────────────────────────────────── */
    var map = L.map('liveMap', { zoomControl: true, attributionControl: true })
               .setView([-2.5, 117.5], 5);
    map.zoomControl.setPosition('bottomright');
    updateTileTheme('default');

    var salesMarkers = {}, cpMarkers = {}, cpCircles = {},
        routeLines  = {}, targetPins = {}, traceInfoMap = {};
    var isFirst = true;

    /* ── Sales icon ─────────────────────────────────────────── */
    function salesIcon(name) {
        var ini = name ? name.charAt(0).toUpperCase() : 'S';
        var ac  = getComputedStyle(document.documentElement).getPropertyValue('--accent').trim() || '#38bdf8';
        var ac2 = getComputedStyle(document.documentElement).getPropertyValue('--accent2').trim() || '#818cf8';
        return L.divIcon({
            html:
                '<div style="position:relative;width:42px;height:42px;">' +
                  '<div style="position:absolute;inset:0;border-radius:50%;background:rgba(56,189,248,0.2);animation:ripple 2s ease-out infinite;"></div>' +
                  '<div style="position:absolute;inset:4px;border-radius:50%;background:linear-gradient(135deg,#1565c0,#38bdf8);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;color:#fff;box-shadow:0 0 18px rgba(56,189,248,0.6);border:2px solid rgba(255,255,255,0.25);">' + ini + '</div>' +
                '</div>',
            className: '', iconSize: [42, 42], iconAnchor: [21, 21]
        });
    }

    /* ── Checkpoint icon ────────────────────────────────────── */
    function cpIconFn(status) {
        var c    = status === 'green' ? '#34d399' : (status === 'yellow' ? '#fbbf24' : '#546e7a');
        var glow = status === 'green' ? 'rgba(52,211,153,0.5)' : (status === 'yellow' ? 'rgba(251,191,36,0.5)' : 'transparent');
        return L.divIcon({
            html:
                '<div style="position:relative;width:28px;height:36px;">' +
                  '<div style="width:28px;height:28px;border-radius:50% 50% 50% 0;transform:rotate(-45deg);background:' + c + ';border:2px solid rgba(255,255,255,0.35);box-shadow:0 0 14px ' + glow + ';"></div>' +
                  '<div style="position:absolute;top:6px;left:6px;width:16px;height:16px;border-radius:50%;background:rgba(255,255,255,0.2);"></div>' +
                '</div>',
            className: '', iconSize: [28, 36], iconAnchor: [14, 36]
        });
    }

    /* ── Popup builders ─────────────────────────────────────── */
    function salesPopup(s) {
        return '<strong>' + s.fullName + '</strong>' +
               '<div style="margin-top:6px;color:rgba(255,255,255,0.45);font-size:.74rem;">' +
               '<div><i class="fas fa-map-marker-alt" style="color:#38bdf8;width:14px;"></i> ' + s.latitude.toFixed(5) + ', ' + s.longitude.toFixed(5) + '</div>' +
               '<div style="margin-top:3px;"><i class="fas fa-clock" style="color:#38bdf8;width:14px;"></i> ' + timeAgo(s.lastSeen) + '</div>' +
               '</div>';
    }
    function cpPopup(cp, statusLabel) {
        return '<strong>' + cp.name + '</strong>' +
               '<div style="margin-top:6px;"><span style="font-size:.7rem;padding:2px 8px;border-radius:20px;background:rgba(255,255,255,0.08);color:#e0f2fe;">' + statusLabel + '</span></div>' +
               '<div style="margin-top:6px;color:rgba(255,255,255,0.4);font-size:.74rem;">' +
               'Tiba: <b style="color:#34d399;">' + cp.arrivedCount + '</b> &nbsp;|&nbsp; Pending: <b style="color:#fbbf24;">' + cp.pendingCount + '</b></div>';
    }
    function timeAgo(dateStr) {
        if (!dateStr) return '—';
        var diff = Math.floor((new Date() - new Date(dateStr)) / 60000);
        if (diff < 1)  return 'Baru saja';
        if (diff < 60) return diff + ' menit lalu';
        return Math.floor(diff / 60) + ' jam lalu';
    }
    function formatMeters(m) {
        if (m == null || isNaN(m)) return '—';
        if (m >= 1000) return (m / 1000).toFixed(2) + ' km';
        return Math.round(m) + ' m';
    }

    /* ── Main update ────────────────────────────────────────── */
    function updateTracking() {
        var now     = new Date();
        var timeStr = now.toLocaleTimeString('id-ID', { hour:'2-digit', minute:'2-digit', second:'2-digit' });
        document.getElementById('sideLastUpdate').textContent    = timeStr;
        document.getElementById('lastRefreshLabel').textContent  = timeStr;

        /* Sales positions */
        fetch('/SalesTracking/GetSalesPositions')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var html = '';
                if (!data.length) {
                    html = '<div class="empty-state"><i class="fas fa-user-slash"></i>Tidak ada sales aktif saat ini</div>';
                }
                data.forEach(function(s) {
                    var trace  = traceInfoMap[s.userId] || null;
                    var tujuan = (trace && trace.target) ? trace.target.checkpointName : 'Belum ada target';
                    var jarak  = (trace && trace.target) ? formatMeters(trace.target.metersToTarget) : '—';

                    if (!salesMarkers[s.userId]) {
                        salesMarkers[s.userId] = L.marker([s.latitude, s.longitude], { icon: salesIcon(s.fullName) })
                            .addTo(map).bindPopup(salesPopup(s), { maxWidth: 230 });
                    } else {
                        salesMarkers[s.userId].setLatLng([s.latitude, s.longitude]);
                        salesMarkers[s.userId].getPopup().setContent(salesPopup(s));
                    }

                    html +=
                        '<div class="sales-card" onclick="flyTo(' + s.latitude + ',' + s.longitude + ',13)">' +
                          '<div class="sales-avatar">' + s.fullName.charAt(0).toUpperCase() + '</div>' +
                          '<div class="sales-info">' +
                            '<div class="s-name">' + s.fullName + '</div>' +
                            '<div class="s-meta"><i class="fas fa-clock"></i>' + timeAgo(s.lastSeen) + '</div>' +
                            '<div class="s-meta"><i class="fas fa-flag-checkered"></i>' + tujuan + '</div>' +
                            '<div class="s-meta"><i class="fas fa-ruler-combined"></i>Jarak: ' + jarak + '</div>' +
                          '</div>' +
                          '<span class="online-pill">Online</span>' +
                        '</div>';
                });

                document.getElementById('salesList').innerHTML = html;
                document.getElementById('statOnline').textContent = data.length;
                document.getElementById('countBadge').textContent = data.length + ' online';

                if (isFirst && data.length > 0) {
                    map.fitBounds(data.map(function(s){ return [s.latitude, s.longitude]; }), { padding: [60,60] });
                }
            });

        /* Traces */
        fetch('/SalesTracking/GetSalesTraces')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                traceInfoMap = {};
                data.forEach(function(item) {
                    traceInfoMap[item.userId] = item;
                    if (item.route && item.route.length >= 2) {
                        var lls = item.route.map(function(p){ return [p.latitude, p.longitude]; });
                        if (!routeLines[item.userId]) {
                            routeLines[item.userId] = L.polyline(lls, { color: '#38bdf8', weight: 3, opacity: .8, dashArray: '6 3' }).addTo(map);
                        } else { routeLines[item.userId].setLatLngs(lls); }
                    }
                    if (item.target) {
                        var tll = [item.target.latitude, item.target.longitude];
                        var pc  = '<strong>Tujuan: ' + item.target.checkpointName + '</strong><br/>Jarak: ' + formatMeters(item.target.metersToTarget);
                        if (!targetPins[item.userId]) {
                            targetPins[item.userId] = L.circleMarker(tll, { radius:6, color:'#fbbf24', weight:2, fillColor:'#f59e0b', fillOpacity:.9 }).addTo(map).bindPopup(pc);
                        } else { targetPins[item.userId].setLatLng(tll); targetPins[item.userId].getPopup().setContent(pc); }
                    }
                });
            });

        /* Checkpoint statuses */
        fetch('/SalesTracking/GetCheckpointStatuses')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var html = '';
                var arrivedCount = 0, pendingCount = 0;
                data.forEach(function(cp) {
                    var status      = cp.arrivedCount > 0 ? 'green'   : (cp.pendingCount > 0 ? 'yellow' : 'none');
                    var statusLabel = cp.arrivedCount > 0 ? 'Sudah Tiba' : (cp.pendingCount > 0 ? 'Pending' : 'Belum Ada');
                    var sbClass     = cp.arrivedCount > 0 ? 'sb-arrived'  : (cp.pendingCount > 0 ? 'sb-pending' : 'sb-none');
                    arrivedCount += cp.arrivedCount;
                    pendingCount += cp.pendingCount;

                    if (!cpMarkers[cp.id]) {
                        cpMarkers[cp.id] = L.marker([cp.latitude, cp.longitude], { icon: cpIconFn(status) })
                            .addTo(map).bindPopup(cpPopup(cp, statusLabel), { maxWidth: 230 });
                        var cc = cp.arrivedCount > 0 ? '#34d399' : (cp.pendingCount > 0 ? '#fbbf24' : '#38bdf8');
                        cpCircles[cp.id] = L.circle([cp.latitude, cp.longitude], { radius: cp.radius, color: cc, weight:1.5, fillColor: cc, fillOpacity: .06, dashArray:'4 4' }).addTo(map);
                    } else {
                        cpMarkers[cp.id].setIcon(cpIconFn(status));
                        cpMarkers[cp.id].getPopup().setContent(cpPopup(cp, statusLabel));
                    }

                    html +=
                        '<div class="cp-card" onclick="flyTo(' + cp.latitude + ',' + cp.longitude + ',14)">' +
                          '<div class="cp-icon-wrap"><i class="fas fa-map-pin"></i></div>' +
                          '<span class="cp-name">' + cp.name + '</span>' +
                          '<span class="status-badge ' + sbClass + '">' + statusLabel + '</span>' +
                        '</div>';
                });

                if (!html) html = '<div class="empty-state"><i class="fas fa-map-marked-alt"></i>Belum ada checkpoint</div>';
                document.getElementById('cpStatusList').innerHTML = html;
                document.getElementById('statArrived').textContent = arrivedCount;
                document.getElementById('statPending').textContent  = pendingCount;

                if (isFirst && data.length > 0 && !Object.keys(salesMarkers).length) {
                    map.fitBounds(data.map(function(cp){ return [cp.latitude, cp.longitude]; }), { padding:[80,80] });
                }
                isFirst = false;
            });
    }

    function flyTo(lat, lng, zoom) { map.flyTo([lat, lng], zoom, { duration: 1.2 }); }

    /* ripple keyframe */
    var s = document.createElement('style');
    s.textContent = '@@keyframes ripple { 0%{transform:scale(1);opacity:.6} 100%{transform:scale(2.8);opacity:0} }';
    document.head.appendChild(s);

    updateTracking();
    setInterval(updateTracking, 15000);
</script>
}


    /* ── tracking wrapper ───────────────────────────────────── */
    .tracking-wrap {
        position: relative;
        width: 100%;
        height: calc(100vh - 70px); /* 70px = topbar */
        display: flex;
        background: #07111f;
        overflow: hidden;
    }

    /* ── map fills entire area ──────────────────────────────── */
    #liveMap {
        flex: 1;
        height: 100%;
        z-index: 1;
    }

    /* ── floating top bar ───────────────────────────────────── */
    .map-topbar {
        position: absolute;
        top: 16px; left: 16px; right: 340px;
        z-index: 500;
        display: flex;
        align-items: center;
        justify-content: space-between;
        pointer-events: none;
    }
    .map-title-badge {
        display: flex; align-items: center; gap: 10px;
        background: rgba(7,17,31,0.88);
        border: 1px solid rgba(33,150,243,0.3);
        border-radius: 10px;
        padding: 10px 18px;
        backdrop-filter: blur(10px);
        box-shadow: 0 4px 20px rgba(0,0,0,0.5);
        pointer-events: auto;
    }
    .map-title-badge .live-dot {
        width: 8px; height: 8px; border-radius: 50%;
        background: #00e676;
        box-shadow: 0 0 10px #00e676;
        animation: blink 1.4s ease-in-out infinite;
        flex-shrink: 0;
    }
    @@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.2} }
    .map-title-badge h6 {
        margin: 0; font-size: 0.9rem; font-weight: 800;
        color: #fff; letter-spacing: 0.5px;
    }
    .map-title-badge small {
        color: rgba(255,255,255,0.35);
        font-size: 0.72rem;
        letter-spacing: 0.5px;
    }
    .map-meta {
        display: flex; gap: 8px;
        pointer-events: auto;
    }
    .meta-chip {
        background: rgba(7,17,31,0.88);
        border: 1px solid rgba(33,150,243,0.2);
        border-radius: 8px;
        padding: 6px 13px;
        backdrop-filter: blur(10px);
        font-size: 0.75rem; color: rgba(255,255,255,0.55);
        display: flex; align-items: center; gap: 6px;
    }
    .meta-chip i { color: #42a5f5; }

    /* ── legend overlay ─────────────────────────────────────── */
    .map-legend {
        position: absolute;
        bottom: 16px; left: 16px;
        z-index: 500;
        background: rgba(7,17,31,0.88);
        border: 1px solid rgba(33,150,243,0.2);
        border-radius: 10px;
        padding: 10px 16px;
        backdrop-filter: blur(10px);
        display: flex; gap: 16px;
    }
    .legend-item {
        display: flex; align-items: center; gap: 7px;
        font-size: 0.75rem; color: rgba(255,255,255,0.55);
    }
    .leg-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }

    /* ── right panel ────────────────────────────────────────── */
    .side-panel {
        width: 320px;
        flex-shrink: 0;
        height: 100%;
        background: #0a1628;
        border-left: 1px solid rgba(33,150,243,0.15);
        display: flex;
        flex-direction: column;
        z-index: 100;
        overflow: hidden;
    }

    /* panel header */
    .side-header {
        padding: 16px 18px 12px;
        border-bottom: 1px solid rgba(33,150,243,0.12);
        background: #071220;
    }
    .side-header h6 {
        margin: 0; font-size: 0.82rem; font-weight: 800;
        letter-spacing: 1px; text-transform: uppercase;
        color: rgba(255,255,255,0.55);
    }

    /* section toggle */
    .panel-section { flex: 1; overflow-y: auto; min-height: 0; }
    .panel-section::-webkit-scrollbar { width: 3px; }
    .panel-section::-webkit-scrollbar-track { background: transparent; }
    .panel-section::-webkit-scrollbar-thumb { background: rgba(33,150,243,0.3); border-radius: 2px; }

    .section-label {
        padding: 12px 18px 6px;
        font-size: 0.68rem; font-weight: 800;
        letter-spacing: 1.5px; text-transform: uppercase;
        color: rgba(33,150,243,0.6);
        display: flex; align-items: center; gap: 8px;
    }
    .section-label::after {
        content: '';
        flex: 1; height: 1px;
        background: rgba(33,150,243,0.12);
    }

    /* sales card */
    .sales-card {
        margin: 4px 12px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(33,150,243,0.12);
        border-radius: 10px;
        padding: 11px 13px;
        display: flex; align-items: center; gap: 11px;
        transition: all 0.2s;
        cursor: pointer;
    }
    .sales-card:hover {
        background: rgba(33,150,243,0.08);
        border-color: rgba(33,150,243,0.3);
    }
    .sales-avatar {
        width: 36px; height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1565c0, #2196f3);
        display: flex; align-items: center; justify-content: center;
        font-size: 14px; font-weight: 800; color: #fff;
        flex-shrink: 0;
        box-shadow: 0 0 12px rgba(33,150,243,0.4);
    }
    .sales-info { flex: 1; min-width: 0; }
    .sales-info .s-name {
        font-size: 0.82rem; font-weight: 700; color: #e3f2fd;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .sales-info .s-meta {
        font-size: 0.7rem; color: rgba(255,255,255,0.35);
        margin-top: 2px;
    }
    .online-pill {
        font-size: 0.65rem; font-weight: 700;
        background: rgba(0,230,118,0.15);
        color: #00e676;
        border: 1px solid rgba(0,230,118,0.3);
        border-radius: 20px;
        padding: 2px 8px;
        white-space: nowrap;
    }

    /* checkpoint card */
    .cp-card {
        margin: 4px 12px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(33,150,243,0.1);
        border-radius: 10px;
        padding: 10px 13px;
        display: flex; align-items: center; justify-content: space-between; gap: 10px;
        transition: all 0.2s;
    }
    .cp-card:hover {
        background: rgba(33,150,243,0.06);
    }
    .cp-card .cp-name {
        font-size: 0.8rem; font-weight: 700; color: #cfd8dc;
        flex: 1; min-width: 0;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .cp-card .cp-icon { color: rgba(33,150,243,0.6); font-size: 0.8rem; margin-right: 7px; flex-shrink: 0; }
    .status-badge {
        font-size: 0.65rem; font-weight: 700;
        border-radius: 20px; padding: 2px 9px;
        white-space: nowrap; flex-shrink: 0;
    }
    .sb-arrived  { background: rgba(28,200,138,0.15); color: #1cc88a; border: 1px solid rgba(28,200,138,0.3); }
    .sb-pending  { background: rgba(246,194,62,0.15);  color: #f6c23e; border: 1px solid rgba(246,194,62,0.3); }
    .sb-none     { background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.3); border: 1px solid rgba(255,255,255,0.1); }

    /* empty state */
    .empty-state {
        padding: 28px 18px;
        text-align: center;
        font-size: 0.8rem;
        color: rgba(255,255,255,0.2);
    }
    .empty-state i { font-size: 1.6rem; margin-bottom: 8px; display: block; opacity: 0.3; }

    /* panel divider */
    .panel-divider { height: 1px; background: rgba(33,150,243,0.1); margin: 8px 0; }

    /* last updated footer */
    .side-footer {
        padding: 10px 18px;
        border-top: 1px solid rgba(33,150,243,0.1);
        font-size: 0.7rem; color: rgba(255,255,255,0.2);
        display: flex; align-items: center; justify-content: space-between;
    }
    .side-footer i { color: rgba(33,150,243,0.5); }

    /* Leaflet popup dark theme */
    .leaflet-popup-content-wrapper {
        background: #0d1e35 !important;
        border: 1px solid rgba(33,150,243,0.35) !important;
        border-radius: 10px !important;
        box-shadow: 0 8px 30px rgba(0,0,0,0.6) !important;
        color: #e3f2fd !important;
    }
    .leaflet-popup-tip { background: #0d1e35 !important; }
    .leaflet-popup-content { margin: 12px 16px !important; font-size: 0.82rem !important; line-height: 1.5 !important; }
    .leaflet-popup-content strong { color: #fff; font-size: 0.88rem; }
    .leaflet-popup-close-button { color: rgba(255,255,255,0.4) !important; font-size: 18px !important; }
    .leaflet-popup-close-button:hover { color: #fff !important; }

    /* Leaflet zoom control */
    .leaflet-control-zoom a {
        background: rgba(7,17,31,0.9) !important;
        border-color: rgba(33,150,243,0.3) !important;
        color: #42a5f5 !important;
    }
    .leaflet-control-zoom a:hover { background: rgba(33,150,243,0.2) !important; }

    /* Attribution */
    .leaflet-control-attribution {
        background: rgba(7,17,31,0.7) !important;
        color: rgba(255,255,255,0.3) !important;
        font-size: 10px !important;
    }
    .leaflet-control-attribution a { color: rgba(33,150,243,0.6) !important; }
</style>
}

