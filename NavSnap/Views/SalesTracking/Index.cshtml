@{
    ViewData["Title"] = "Live Sales Tracking";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script>document.body.classList.add('page-tracking');</script>

@section Styles {
<style>
    /* ── override content padding so map can go edge-to-edge ─── */
    #content { padding: 0 !important; }
    .container-fluid { padding: 0 !important; }

    /* ── tracking wrapper ───────────────────────────────────── */
    .tracking-wrap {
        position: relative;
        width: 100%;
        height: calc(100vh - 70px); /* 70px = topbar */
        display: flex;
        background: #07111f;
        overflow: hidden;
    }

    /* ── map fills entire area ──────────────────────────────── */
    #liveMap {
        flex: 1;
        height: 100%;
        z-index: 1;
    }

    /* ── floating top bar ───────────────────────────────────── */
    .map-topbar {
        position: absolute;
        top: 16px; left: 16px; right: 340px;
        z-index: 500;
        display: flex;
        align-items: center;
        justify-content: space-between;
        pointer-events: none;
    }
    .map-title-badge {
        display: flex; align-items: center; gap: 10px;
        background: rgba(7,17,31,0.88);
        border: 1px solid rgba(33,150,243,0.3);
        border-radius: 10px;
        padding: 10px 18px;
        backdrop-filter: blur(10px);
        box-shadow: 0 4px 20px rgba(0,0,0,0.5);
        pointer-events: auto;
    }
    .map-title-badge .live-dot {
        width: 8px; height: 8px; border-radius: 50%;
        background: #00e676;
        box-shadow: 0 0 10px #00e676;
        animation: blink 1.4s ease-in-out infinite;
        flex-shrink: 0;
    }
    @@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.2} }
    .map-title-badge h6 {
        margin: 0; font-size: 0.9rem; font-weight: 800;
        color: #fff; letter-spacing: 0.5px;
    }
    .map-title-badge small {
        color: rgba(255,255,255,0.35);
        font-size: 0.72rem;
        letter-spacing: 0.5px;
    }
    .map-meta {
        display: flex; gap: 8px;
        pointer-events: auto;
    }
    .meta-chip {
        background: rgba(7,17,31,0.88);
        border: 1px solid rgba(33,150,243,0.2);
        border-radius: 8px;
        padding: 6px 13px;
        backdrop-filter: blur(10px);
        font-size: 0.75rem; color: rgba(255,255,255,0.55);
        display: flex; align-items: center; gap: 6px;
    }
    .meta-chip i { color: #42a5f5; }

    /* ── legend overlay ─────────────────────────────────────── */
    .map-legend {
        position: absolute;
        bottom: 16px; left: 16px;
        z-index: 500;
        background: rgba(7,17,31,0.88);
        border: 1px solid rgba(33,150,243,0.2);
        border-radius: 10px;
        padding: 10px 16px;
        backdrop-filter: blur(10px);
        display: flex; gap: 16px;
    }
    .legend-item {
        display: flex; align-items: center; gap: 7px;
        font-size: 0.75rem; color: rgba(255,255,255,0.55);
    }
    .leg-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }

    /* ── right panel ────────────────────────────────────────── */
    .side-panel {
        width: 320px;
        flex-shrink: 0;
        height: 100%;
        background: #0a1628;
        border-left: 1px solid rgba(33,150,243,0.15);
        display: flex;
        flex-direction: column;
        z-index: 100;
        overflow: hidden;
    }

    /* panel header */
    .side-header {
        padding: 16px 18px 12px;
        border-bottom: 1px solid rgba(33,150,243,0.12);
        background: #071220;
    }
    .side-header h6 {
        margin: 0; font-size: 0.82rem; font-weight: 800;
        letter-spacing: 1px; text-transform: uppercase;
        color: rgba(255,255,255,0.55);
    }

    /* section toggle */
    .panel-section { flex: 1; overflow-y: auto; min-height: 0; }
    .panel-section::-webkit-scrollbar { width: 3px; }
    .panel-section::-webkit-scrollbar-track { background: transparent; }
    .panel-section::-webkit-scrollbar-thumb { background: rgba(33,150,243,0.3); border-radius: 2px; }

    .section-label {
        padding: 12px 18px 6px;
        font-size: 0.68rem; font-weight: 800;
        letter-spacing: 1.5px; text-transform: uppercase;
        color: rgba(33,150,243,0.6);
        display: flex; align-items: center; gap: 8px;
    }
    .section-label::after {
        content: '';
        flex: 1; height: 1px;
        background: rgba(33,150,243,0.12);
    }

    /* sales card */
    .sales-card {
        margin: 4px 12px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(33,150,243,0.12);
        border-radius: 10px;
        padding: 11px 13px;
        display: flex; align-items: center; gap: 11px;
        transition: all 0.2s;
        cursor: pointer;
    }
    .sales-card:hover {
        background: rgba(33,150,243,0.08);
        border-color: rgba(33,150,243,0.3);
    }
    .sales-avatar {
        width: 36px; height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1565c0, #2196f3);
        display: flex; align-items: center; justify-content: center;
        font-size: 14px; font-weight: 800; color: #fff;
        flex-shrink: 0;
        box-shadow: 0 0 12px rgba(33,150,243,0.4);
    }
    .sales-info { flex: 1; min-width: 0; }
    .sales-info .s-name {
        font-size: 0.82rem; font-weight: 700; color: #e3f2fd;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .sales-info .s-meta {
        font-size: 0.7rem; color: rgba(255,255,255,0.35);
        margin-top: 2px;
    }
    .online-pill {
        font-size: 0.65rem; font-weight: 700;
        background: rgba(0,230,118,0.15);
        color: #00e676;
        border: 1px solid rgba(0,230,118,0.3);
        border-radius: 20px;
        padding: 2px 8px;
        white-space: nowrap;
    }

    /* checkpoint card */
    .cp-card {
        margin: 4px 12px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(33,150,243,0.1);
        border-radius: 10px;
        padding: 10px 13px;
        display: flex; align-items: center; justify-content: space-between; gap: 10px;
        transition: all 0.2s;
    }
    .cp-card:hover {
        background: rgba(33,150,243,0.06);
    }
    .cp-card .cp-name {
        font-size: 0.8rem; font-weight: 700; color: #cfd8dc;
        flex: 1; min-width: 0;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .cp-card .cp-icon { color: rgba(33,150,243,0.6); font-size: 0.8rem; margin-right: 7px; flex-shrink: 0; }
    .status-badge {
        font-size: 0.65rem; font-weight: 700;
        border-radius: 20px; padding: 2px 9px;
        white-space: nowrap; flex-shrink: 0;
    }
    .sb-arrived  { background: rgba(28,200,138,0.15); color: #1cc88a; border: 1px solid rgba(28,200,138,0.3); }
    .sb-pending  { background: rgba(246,194,62,0.15);  color: #f6c23e; border: 1px solid rgba(246,194,62,0.3); }
    .sb-none     { background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.3); border: 1px solid rgba(255,255,255,0.1); }

    /* empty state */
    .empty-state {
        padding: 28px 18px;
        text-align: center;
        font-size: 0.8rem;
        color: rgba(255,255,255,0.2);
    }
    .empty-state i { font-size: 1.6rem; margin-bottom: 8px; display: block; opacity: 0.3; }

    /* panel divider */
    .panel-divider { height: 1px; background: rgba(33,150,243,0.1); margin: 8px 0; }

    /* last updated footer */
    .side-footer {
        padding: 10px 18px;
        border-top: 1px solid rgba(33,150,243,0.1);
        font-size: 0.7rem; color: rgba(255,255,255,0.2);
        display: flex; align-items: center; justify-content: space-between;
    }
    .side-footer i { color: rgba(33,150,243,0.5); }

    /* Leaflet popup dark theme */
    .leaflet-popup-content-wrapper {
        background: #0d1e35 !important;
        border: 1px solid rgba(33,150,243,0.35) !important;
        border-radius: 10px !important;
        box-shadow: 0 8px 30px rgba(0,0,0,0.6) !important;
        color: #e3f2fd !important;
    }
    .leaflet-popup-tip { background: #0d1e35 !important; }
    .leaflet-popup-content { margin: 12px 16px !important; font-size: 0.82rem !important; line-height: 1.5 !important; }
    .leaflet-popup-content strong { color: #fff; font-size: 0.88rem; }
    .leaflet-popup-close-button { color: rgba(255,255,255,0.4) !important; font-size: 18px !important; }
    .leaflet-popup-close-button:hover { color: #fff !important; }

    /* Leaflet zoom control */
    .leaflet-control-zoom a {
        background: rgba(7,17,31,0.9) !important;
        border-color: rgba(33,150,243,0.3) !important;
        color: #42a5f5 !important;
    }
    .leaflet-control-zoom a:hover { background: rgba(33,150,243,0.2) !important; }

    /* Attribution */
    .leaflet-control-attribution {
        background: rgba(7,17,31,0.7) !important;
        color: rgba(255,255,255,0.3) !important;
        font-size: 10px !important;
    }
    .leaflet-control-attribution a { color: rgba(33,150,243,0.6) !important; }
</style>
}

<div class="tracking-wrap">

    <!-- ── Map ─────────────────────────────────────────────── -->
    <div id="liveMap"></div>

    <!-- ── Floating top bar ─────────────────────────────────── -->
    <div class="map-topbar">
        <div class="map-title-badge">
            <div class="live-dot"></div>
            <div>
                <h6><i class="fas fa-satellite-dish mr-2" style="color:#42a5f5;"></i>Live Sales Tracking</h6>
                <small>Auto-refresh setiap 15 detik</small>
            </div>
        </div>
        <div class="map-meta">
            <div class="meta-chip"><i class="fas fa-circle" style="color:#2196f3;font-size:8px;"></i>Sales</div>
            <div class="meta-chip"><i class="fas fa-map-pin"></i>Checkpoint</div>
            <div class="meta-chip" id="lastRefreshChip"><i class="fas fa-sync-alt"></i><span id="lastRefreshLabel">—</span></div>
        </div>
    </div>

    <!-- ── Legend ───────────────────────────────────────────── -->
    <div class="map-legend">
        <div class="legend-item"><div class="leg-dot" style="background:#2196f3;box-shadow:0 0 8px #2196f3;"></div>Sales Online</div>
        <div class="legend-item"><div class="leg-dot" style="background:#1cc88a;"></div>Sudah Tiba</div>
        <div class="legend-item"><div class="leg-dot" style="background:#f6c23e;"></div>Pending</div>
        <div class="legend-item"><div class="leg-dot" style="background:#546e7a;"></div>Belum Ditugaskan</div>
    </div>

    <!-- ── Right panel ──────────────────────────────────────── -->
    <div class="side-panel">
        <div class="side-header">
            <h6><i class="fas fa-broadcast-tower mr-2" style="color:#2196f3;"></i>Panel Monitoring</h6>
        </div>

        <div class="panel-section">
            <!-- Sales -->
            <div class="section-label"><i class="fas fa-users" style="color:#42a5f5;"></i>Sales Aktif</div>
            <div id="salesList">
                <div class="empty-state"><i class="fas fa-user-slash"></i>Memuat data sales...</div>
            </div>

            <div class="panel-divider"></div>

            <!-- Checkpoints -->
            <div class="section-label"><i class="fas fa-map-pin" style="color:#42a5f5;"></i>Status Checkpoint Hari Ini</div>
            <div id="cpStatusList">
                <div class="empty-state"><i class="fas fa-map-marker-alt"></i>Memuat checkpoint...</div>
            </div>
        </div>

        <div class="side-footer">
            <span><i class="fas fa-clock mr-1"></i>Terakhir update: <span id="sideLastUpdate">—</span></span>
            <span id="countBadge" style="color:rgba(33,150,243,0.6);font-weight:700;"></span>
        </div>
    </div>

</div>

@section Scripts {
<script>
    /* ── Init map with dark tile ──────────────────────────── */
    var map = L.map('liveMap', {
        zoomControl: true,
        attributionControl: true
    }).setView([-2.5, 117.5], 5);

    /* CartoDB Dark Matter — premium dark map */
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://carto.com/">CARTO</a> &copy; <a href="https://www.openstreetmap.org/copyright">OSM</a>',
        subdomains: 'abcd',
        maxZoom: 19
    }).addTo(map);

    /* move zoom control to bottom-right */
    map.zoomControl.setPosition('bottomright');

    var salesMarkers = {};
    var cpMarkers    = {};
    var cpCircles    = {};
    var isFirst      = true;

    /* ── Sales icon — glowing circle ───────────────────────── */
    function salesIcon(name) {
        var ini = name ? name.charAt(0).toUpperCase() : 'S';
        return L.divIcon({
            html:
                '<div style="position:relative;width:40px;height:40px;">' +
                  '<div style="position:absolute;inset:0;border-radius:50%;background:rgba(33,150,243,0.25);animation:ripple 1.8s ease-out infinite;"></div>' +
                  '<div style="position:absolute;inset:4px;border-radius:50%;background:linear-gradient(135deg,#1565c0,#2196f3);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:#fff;box-shadow:0 0 16px rgba(33,150,243,0.7);border:2px solid rgba(255,255,255,0.3);">' + ini + '</div>' +
                '</div>',
            className: '',
            iconSize:   [40, 40],
            iconAnchor: [20, 20]
        });
    }

    /* ── Checkpoint icon — teardrop pin ─────────────────────── */
    function cpIconFn(status) {
        var c = status === 'green' ? '#1cc88a' : (status === 'yellow' ? '#f6c23e' : '#546e7a');
        var glow = status === 'green' ? 'rgba(28,200,138,0.5)' : (status === 'yellow' ? 'rgba(246,194,62,0.5)' : 'transparent');
        return L.divIcon({
            html:
                '<div style="position:relative;width:28px;height:36px;">' +
                  '<div style="position:absolute;top:0;left:0;width:28px;height:28px;border-radius:50% 50% 50% 0;transform:rotate(-45deg);background:' + c + ';border:2px solid rgba(255,255,255,0.4);box-shadow:0 0 14px ' + glow + ';"></div>' +
                  '<div style="position:absolute;top:6px;left:6px;width:16px;height:16px;border-radius:50%;background:rgba(255,255,255,0.25);"></div>' +
                '</div>',
            className: '',
            iconSize:   [28, 36],
            iconAnchor: [14, 36]
        });
    }

    /* ── Popup HTML ─────────────────────────────────────────── */
    function salesPopup(s) {
        return '<strong>' + s.fullName + '</strong>' +
               '<div style="margin-top:6px;color:rgba(255,255,255,0.5);font-size:0.75rem;">' +
               '<div><i class="fas fa-map-marker-alt" style="color:#42a5f5;width:14px;"></i> ' + s.latitude.toFixed(5) + ', ' + s.longitude.toFixed(5) + '</div>' +
               '<div style="margin-top:3px;"><i class="fas fa-clock" style="color:#42a5f5;width:14px;"></i> ' + timeAgo(s.lastSeen) + '</div>' +
               '</div>';
    }
    function cpPopup(cp, statusLabel, statusCls) {
        return '<strong>' + cp.name + '</strong>' +
               '<div style="margin-top:6px;"><span style="font-size:0.7rem;padding:2px 8px;border-radius:20px;background:rgba(255,255,255,0.1);color:#e3f2fd;">' + statusLabel + '</span></div>' +
               '<div style="margin-top:6px;color:rgba(255,255,255,0.45);font-size:0.75rem;">' +
               'Tiba: <b style="color:#1cc88a;">' + cp.arrivedCount + '</b> &nbsp;|&nbsp; Pending: <b style="color:#f6c23e;">' + cp.pendingCount + '</b></div>';
    }

    function timeAgo(dateStr) {
        if (!dateStr) return '—';
        var diff = Math.floor((new Date() - new Date(dateStr)) / 60000);
        if (diff < 1)  return 'Baru saja';
        if (diff < 60) return diff + ' menit lalu';
        return Math.floor(diff / 60) + ' jam lalu';
    }

    /* ── Update tracking data ───────────────────────────────── */
    function updateTracking() {
        var now = new Date();
        var timeStr = now.toLocaleTimeString('id-ID', { hour:'2-digit', minute:'2-digit', second:'2-digit' });
        document.getElementById('sideLastUpdate').textContent = timeStr;
        document.getElementById('lastRefreshLabel').textContent = timeStr;

        /* Sales positions */
        fetch('/SalesTracking/GetSalesPositions')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var html = '';
                if (data.length === 0) {
                    html = '<div class="empty-state"><i class="fas fa-user-slash"></i>Tidak ada sales aktif saat ini</div>';
                }
                data.forEach(function(s) {
                    if (!salesMarkers[s.userId]) {
                        salesMarkers[s.userId] = L.marker([s.latitude, s.longitude], { icon: salesIcon(s.fullName) })
                            .addTo(map)
                            .bindPopup(salesPopup(s), { maxWidth: 220 });
                    } else {
                        salesMarkers[s.userId].setLatLng([s.latitude, s.longitude]);
                        salesMarkers[s.userId].getPopup().setContent(salesPopup(s));
                    }

                    html += '<div class="sales-card" onclick="flyTo(' + s.latitude + ',' + s.longitude + ',13)">' +
                        '<div class="sales-avatar">' + s.fullName.charAt(0).toUpperCase() + '</div>' +
                        '<div class="sales-info">' +
                          '<div class="s-name">' + s.fullName + '</div>' +
                          '<div class="s-meta"><i class="fas fa-clock mr-1"></i>' + timeAgo(s.lastSeen) + '</div>' +
                        '</div>' +
                        '<span class="online-pill">● Online</span>' +
                        '</div>';
                });
                document.getElementById('salesList').innerHTML = html;
                document.getElementById('countBadge').textContent = data.length + ' online';

                if (isFirst && data.length > 0) {
                    var latlngs = data.map(function(s) { return [s.latitude, s.longitude]; });
                    map.fitBounds(latlngs, { padding: [60, 60] });
                }
            });

        /* Checkpoint statuses */
        fetch('/SalesTracking/GetCheckpointStatuses')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var html = '';
                data.forEach(function(cp) {
                    var status      = cp.arrivedCount > 0 ? 'green'   : (cp.pendingCount > 0 ? 'yellow' : 'none');
                    var statusLabel = cp.arrivedCount > 0 ? 'Sudah Tiba' : (cp.pendingCount > 0 ? 'Pending' : 'Belum Ada');
                    var sbClass     = cp.arrivedCount > 0 ? 'sb-arrived'  : (cp.pendingCount > 0 ? 'sb-pending' : 'sb-none');

                    if (!cpMarkers[cp.id]) {
                        cpMarkers[cp.id] = L.marker([cp.latitude, cp.longitude], { icon: cpIconFn(status) })
                            .addTo(map)
                            .bindPopup(cpPopup(cp, statusLabel, sbClass), { maxWidth: 220 });

                        var circleColor = cp.arrivedCount > 0 ? '#1cc88a' : (cp.pendingCount > 0 ? '#f6c23e' : '#42a5f5');
                        cpCircles[cp.id] = L.circle([cp.latitude, cp.longitude], {
                            radius: cp.radius,
                            color: circleColor, weight: 1.5,
                            fillColor: circleColor, fillOpacity: 0.07,
                            dashArray: '4 4'
                        }).addTo(map);
                    } else {
                        cpMarkers[cp.id].setIcon(cpIconFn(status));
                        cpMarkers[cp.id].getPopup().setContent(cpPopup(cp, statusLabel, sbClass));
                    }

                    html += '<div class="cp-card" onclick="flyTo(' + cp.latitude + ',' + cp.longitude + ',14)">' +
                        '<i class="fas fa-map-pin cp-icon"></i>' +
                        '<span class="cp-name">' + cp.name + '</span>' +
                        '<span class="status-badge ' + sbClass + '">' + statusLabel + '</span>' +
                        '</div>';
                });

                if (!html) html = '<div class="empty-state"><i class="fas fa-map-marker-alt"></i>Belum ada checkpoint</div>';
                document.getElementById('cpStatusList').innerHTML = html;

                if (isFirst && data.length > 0 && Object.keys(salesMarkers).length === 0) {
                    var latlngs = data.map(function(cp) { return [cp.latitude, cp.longitude]; });
                    if (latlngs.length > 0) map.fitBounds(latlngs, { padding: [80, 80] });
                }
                isFirst = false;
            });
    }

    function flyTo(lat, lng, zoom) {
        map.flyTo([lat, lng], zoom, { duration: 1.2 });
    }

    /* CSS ripple for sales markers */
    var style = document.createElement('style');
    style.textContent = '@@keyframes ripple { 0%{transform:scale(1);opacity:.6} 100%{transform:scale(2.5);opacity:0} }';
    document.head.appendChild(style);

    updateTracking();
    setInterval(updateTracking, 15000);
</script>
}

