@model NavSnap.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
    /* ════════════════════════════════════════════════════════
       FUTURISTIC ANIMATIONS (light theme preserved)
    ════════════════════════════════════════════════════════ */

    /* entrance animation */
    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(22px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    @@keyframes fadeIn {
        from { opacity: 0; } to { opacity: 1; }
    }
    /* shimmer sweep */
    @@keyframes shimmer {
        0%   { background-position: -600px 0; }
        100% { background-position: 600px 0; }
    }
    /* pulse glow ring */
    @@keyframes pulseRing {
        0%   { transform: scale(1); opacity: .7; }
        100% { transform: scale(1.55); opacity: 0; }
    }
    /* scanning line */
    @@keyframes scanLine {
        0%   { top: 0; }
        100% { top: 100%; }
    }
    /* orbit spin */
    @@keyframes orbitSpin {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
    }
    /* hero grid float */
    @@keyframes heroFloat {
        0%, 100% { transform: translateY(0); }
        50%      { transform: translateY(-5px); }
    }
    /* bar fill */
    @@keyframes barFill {
        from { width: 0 !important; }
    }
    /* counter pop */
    @@keyframes countPop {
        0%   { transform: scale(.7); opacity: 0; }
        70%  { transform: scale(1.08); }
        100% { transform: scale(1); opacity: 1; }
    }
    /* glitch flicker */
    @@keyframes glitch {
        0%, 90%, 100% { clip-path: none; transform: none; }
        92%  { clip-path: inset(30% 0 40% 0); transform: translate(-2px); }
        94%  { clip-path: inset(60% 0 10% 0); transform: translate(2px); }
        96%  { clip-path: inset(10% 0 70% 0); transform: translate(-1px); }
    }
    /* stagger classes */
    .anim-1 { animation: slideUp .5s ease both; }
    .anim-2 { animation: slideUp .5s .08s ease both; }
    .anim-3 { animation: slideUp .5s .16s ease both; }
    .anim-4 { animation: slideUp .5s .24s ease both; }
    .anim-5 { animation: slideUp .5s .32s ease both; }
    .anim-6 { animation: slideUp .5s .40s ease both; }
    .anim-7 { animation: slideUp .5s .48s ease both; }
    .anim-8 { animation: slideUp .5s .56s ease both; }

    /* ── shell ── */
    .dash-shell {
        --dash-indigo: #1f4ed8;
        --dash-cyan: #0ea5e9;
        --dash-emerald: #0ea879;
        --dash-amber: #c6922a;
        --dash-rose: #cf5c74;
        --dash-ink: #0f2034;
        --dash-soft-bg: #ecf4ff;
        --dash-gold: #d4a84f;
        margin-bottom: 1.5rem;
    }
    .dash-hero {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.4rem 1.5rem;
        border: 1px solid rgba(31,78,216,.18);
        border-radius: 16px;
        background:
            radial-gradient(circle at 85% 5%,  rgba(12,198,255,.22), transparent 22rem),
            radial-gradient(circle at 10% 90%, rgba(63,94,251,.15), transparent 20rem),
            radial-gradient(circle at 50% 50%, rgba(14,165,233,.06), transparent 18rem),
            linear-gradient(120deg, rgba(255,255,255,.99), rgba(237,246,255,.99));
        box-shadow: 0 8px 40px rgba(23,35,49,.11), inset 0 1px 0 rgba(255,255,255,.9);
        position: relative;
        overflow: hidden;
        animation: slideUp .45s ease both;
    }
    /* animated dot-grid bg */
    .dash-hero::before {
        content: '';
        position: absolute; inset: 0;
        background-image: radial-gradient(circle, rgba(31,78,216,.06) 1px, transparent 1px);
        background-size: 28px 28px;
        pointer-events: none;
    }
    /* orbit accent */
    .hero-orbit {
        position: absolute; right: 200px; top: -30px;
        width: 120px; height: 120px;
        border-radius: 50%;
        border: 1px dashed rgba(31,78,216,.12);
        animation: orbitSpin 18s linear infinite;
        pointer-events: none;
    }
    .hero-orbit::after {
        content: '';
        position: absolute; top: 10px; left: 50%;
        width: 6px; height: 6px; border-radius: 50%;
        background: rgba(31,78,216,.25);
        transform: translateX(-50%);
    }
    .dash-title {
        margin: 0;
        font-size: 1.08rem;
        font-weight: 800;
        color: #1c2f42;
        line-height: 1.25;
        position: relative; z-index: 1;
        animation: glitch 8s steps(1) infinite;
    }
    .dash-sub {
        margin: .25rem 0 0;
        color: #6b7d8f;
        font-size: .82rem;
        position: relative; z-index: 1;
    }
    .hero-right { display: flex; align-items: center; gap: 12px; position:relative;z-index:1; }
    .dash-date-chip {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        border: 1px solid rgba(15,107,143,.24);
        border-radius: 10px;
        padding: .6rem .85rem;
        background: rgba(15,107,143,.07);
        color: #0c4f69;
        font-size: .78rem;
        font-weight: 700;
        white-space: nowrap;
    }
    .hero-stat {
        display: flex; flex-direction: column; align-items: center;
        gap: 2px;
        background: rgba(31,78,216,.05);
        border: 1px solid rgba(31,78,216,.12);
        border-radius: 10px;
        padding: .45rem .8rem;
        min-width: 72px;
    }
    .hero-stat-val {
        font-size: .95rem; font-weight: 800; color: #1c2f42; line-height: 1;
    }
    .hero-stat-lbl {
        font-size: .62rem; font-weight: 700; color: #7a8fa0;
        text-transform: uppercase; letter-spacing: .05em;
    }
    .kpi-card {
        border: 1px solid #d9e6ef !important;
        border-radius: 14px !important;
        box-shadow: 0 4px 20px rgba(23, 35, 49, .08) !important;
        overflow: hidden;
        position: relative;
        transition: transform .22s ease, box-shadow .22s ease;
        background: #fff;
    }
    /* glowing top accent bar */
    .kpi-card::before {
        content: '';
        position: absolute; top: 0; left: 0; right: 0;
        height: 3px;
        opacity: 0;
        transition: opacity .25s;
    }
    .kpi-card:hover::before { opacity: 1; }
    .kpi-blue::before   { background: linear-gradient(90deg,#1f53ff,#0cc6ff); }
    .kpi-cyan::before   { background: linear-gradient(90deg,#0090d3,#2ad8f8); }
    .kpi-green::before  { background: linear-gradient(90deg,#03a66f,#20d394); }
    .kpi-amber::before  { background: linear-gradient(90deg,#db8f00,#ffc436); }
    .kpi-purple::before { background: linear-gradient(90deg,#5742ff,#7f8dff); }
    .kpi-navy::before   { background: linear-gradient(90deg,#203a63,#3f5efb); }
    .kpi-card:hover { transform: translateY(-4px); box-shadow: 0 16px 36px rgba(23,35,49,.13) !important; }
    /* shimmer on hover */
    .kpi-card::after {
        content: '';
        position: absolute; inset: 0;
        background: linear-gradient(110deg, transparent 30%, rgba(255,255,255,.55) 50%, transparent 70%);
        background-size: 600px 100%;
        opacity: 0;
        transition: opacity .2s;
        pointer-events: none;
    }
    .kpi-card:hover::after { opacity: 1; animation: shimmer .7s ease; }
    .kpi-card .card-body { padding: 1rem 1.1rem; }
    .kpi-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: .6rem;
    }
    .kpi-label {
        font-size: .68rem;
        text-transform: uppercase;
        letter-spacing: .07em;
        font-weight: 800;
        color: #5f7589;
        margin: 0;
    }
    .kpi-icon {
        width: 38px; height: 38px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        color: #fff;
        position: relative;
    }
    /* pulse ring behind icon */
    .kpi-icon::after {
        content: '';
        position: absolute; inset: 0;
        border-radius: inherit;
        animation: pulseRing 2.4s ease-out infinite;
    }
    .kpi-blue .kpi-icon { background: linear-gradient(135deg, #1f53ff, #0cc6ff); }
    .kpi-blue .kpi-icon::after { background: rgba(31,83,255,.18); }
    .kpi-cyan .kpi-icon { background: linear-gradient(135deg, #0090d3, #2ad8f8); }
    .kpi-cyan .kpi-icon::after { background: rgba(0,144,211,.18); }
    .kpi-green .kpi-icon { background: linear-gradient(135deg, #03a66f, #20d394); }
    .kpi-green .kpi-icon::after { background: rgba(3,166,111,.18); }
    .kpi-amber .kpi-icon { background: linear-gradient(135deg, #db8f00, #ffc436); }
    .kpi-amber .kpi-icon::after { background: rgba(219,143,0,.18); }
    .kpi-purple .kpi-icon { background: linear-gradient(135deg, #5742ff, #7f8dff); }
    .kpi-purple .kpi-icon::after { background: rgba(87,66,255,.18); }
    .kpi-navy .kpi-icon { background: linear-gradient(135deg, #203a63, #3f5efb); }
    .kpi-navy .kpi-icon::after { background: rgba(32,58,99,.18); }
    .kpi-value {
        margin: 0;
        color: #13283a;
        font-size: 1.6rem;
        font-weight: 800;
        line-height: 1.05;
        animation: countPop .5s ease both;
    }
    .kpi-note {
        margin-top: .3rem;
        color: #6c8193;
        font-size: .77rem;
        font-weight: 600;
    }
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
        margin-bottom: 1.1rem;
    }
    .quick-grid{
        display:grid;
        grid-template-columns:repeat(4,minmax(0,1fr));
        gap:.75rem;
        margin:-.1rem 0 1rem;
    }
    .quick-link{
        display:flex;align-items:center;gap:.55rem;
        border:1px solid #dce8f0;border-radius:10px;
        padding:.7rem .8rem;background:#fff;color:#17304a;
        text-decoration:none;font-size:.78rem;font-weight:700;
        box-shadow:0 4px 16px rgba(23,35,49,.06);
    }
    .quick-link:hover{background:#f3f9ff;color:#0f3b5a;text-decoration:none}

    .panel-card {
        border-radius: 14px !important;
        overflow: hidden;
        box-shadow: 0 4px 24px rgba(23,35,49,.09) !important;
        border: 1px solid #dce8f0 !important;
    }
    .panel-head {
        padding: .9rem 1.1rem !important;
        border-bottom: 1px solid rgba(255,255,255,.1);
        background: linear-gradient(135deg, #0e4d6e, #0f6b8f, #0ea5e9) !important;
        color: #fff !important;
        position: relative;
        overflow: hidden;
    }
    /* scan line animation on panel head */
    .panel-head::after {
        content: '';
        position: absolute;
        left: 0; right: 0;
        height: 1px;
        background: rgba(255,255,255,.15);
        animation: scanLine 3s linear infinite;
        pointer-events: none;
    }
    .panel-head h6 {
        margin: 0;
        font-weight: 800;
        font-size: .84rem;
        letter-spacing: .02em;
        position: relative; z-index: 1;
    }
    .panel-meta {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        border-radius: 999px;
        padding: .28rem .65rem;
        background: rgba(255,255,255,.18);
        color: #fff;
        font-size: .72rem;
        font-weight: 700;
        position: relative; z-index: 1;
        border: 1px solid rgba(255,255,255,.2);
        backdrop-filter: blur(4px);
    }
    /* live dot */
    .live-indicator {
        display: inline-flex; align-items: center; gap: 5px;
        position: relative; z-index:1;
    }
    .live-dot {
        width: 7px; height: 7px; border-radius: 50%;
        background: #4ade80;
        box-shadow: 0 0 0 0 rgba(74,222,128,.5);
        animation: livePulse 1.8s ease-in-out infinite;
        flex-shrink: 0;
    }
    @@keyframes livePulse {
        0%   { box-shadow: 0 0 0 0 rgba(74,222,128,.5); }
        70%  { box-shadow: 0 0 0 7px rgba(74,222,128,0); }
        100% { box-shadow: 0 0 0 0 rgba(74,222,128,0); }
    }
    #dashMap { height: 380px; }
    .mini-empty {
        text-align: center;
        color: #788b9d;
        padding: 1.5rem;
        font-size: .82rem;
    }
    .visit-table td, .visit-table th { vertical-align: middle; }
    .visit-table thead th {
        font-size: .7rem; font-weight: 800;
        text-transform: uppercase; letter-spacing: .06em;
        color: #4d6880; background: #f3f8fd;
        border-bottom: 2px solid #dce8f4;
    }
    .visit-table tbody tr {
        transition: background .12s;
        animation: fadeIn .3s ease both;
    }
    .visit-table tbody tr:hover { background: #f0f7ff; }
    .visit-table td { font-size: .82rem; border-color: #eef4fb; }
    .visit-name {
        max-width: 120px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-weight: 700; color: #1c3148;
    }
    .visit-cp {
        max-width: 160px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: #446277;
    }
    .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        border-radius: 6px;
        padding: .18rem .6rem;
        font-size: .67rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .04em;
    }
    .status-arrived  { background: rgba(24,167,122,.12); color: #0f6748; border: 1px solid rgba(24,167,122,.2); }
    .status-completed{ background: rgba(43,187,216,.12); color: #0c5e79; border: 1px solid rgba(43,187,216,.2); }
    .status-skipped  { background: rgba(217,76,76,.12);  color: #8f2c2c; border: 1px solid rgba(217,76,76,.2); }
    .status-pending  { background: rgba(214,155,23,.12); color: #7a520a; border: 1px solid rgba(214,155,23,.2); }
    .sales-ana-card {
        border-radius: 14px !important;
        overflow: hidden;
    }
    .sales-ana-card table thead th {
        font-size: .7rem; font-weight: 800;
        text-transform: uppercase; letter-spacing: .06em;
        color: #4d6880; background: #f3f8fd;
        border-bottom: 2px solid #dce8f4;
    }
    .sales-ana-card table tbody tr {
        transition: background .12s;
    }
    .sales-ana-card table tbody tr:hover { background: #f0f7ff; }
    .sales-ana-card table td { font-size: .82rem; border-color: #eef4fb; vertical-align: middle; }
    /* progress bar in performance row */
    .perf-bar-wrap {
        display: flex; align-items: center; gap: 8px;
    }
    .perf-bar {
        flex: 1; height: 6px; border-radius: 999px;
        background: #e3edf6; overflow: hidden; min-width: 60px;
    }
    .perf-bar > span {
        display: block; height: 100%; border-radius: 999px;
        background: linear-gradient(90deg,#1f4ed8,#0ea5e9);
        animation: barFill .8s ease both;
    }
    .perf-bar.warn > span { background: linear-gradient(90deg,#db8f00,#ffc436); }
    .perf-bar.danger > span { background: linear-gradient(90deg,#c53030,#f56565); }
    .sales-row { display: flex; align-items: center; gap: .75rem; }
    .sales-photo {
        width: 40px; height: 40px;
        border-radius: 50%; object-fit: cover;
        border: 2px solid rgba(15,107,143,.28); flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(15,107,143,.15);
    }
    .sales-photo-fallback {
        width: 40px; height: 40px;
        border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: .78rem; font-weight: 800; color: #fff;
        background: linear-gradient(135deg, #0f6b8f, #2bbbd8);
        flex-shrink: 0;
        box-shadow: 0 0 0 3px rgba(15,107,143,.12);
    }
    .sales-name { margin: 0; color: #183044; font-size: .83rem; font-weight: 800; line-height: 1.15; }
    .sales-job  { margin: .16rem 0 0; color: #6c8296; font-size: .7rem; font-weight: 700; }
    .star-wrap { color: #e4a11b; font-size: .76rem; letter-spacing: .04em; }
    .star-muted { color: #d2dbe2; }
    .achv-text {
        display: inline-flex; align-items: center;
        border-radius: 6px; padding: .18rem .55rem;
        font-size: .7rem; font-weight: 800;
        background: rgba(15,107,143,.1); color: #0c5f7f;
        border: 1px solid rgba(15,107,143,.15);
    }
    .online-badge {
        display: inline-flex; align-items: center; gap: 5px;
        border-radius: 6px; padding: .16rem .55rem;
        font-size: .68rem; font-weight: 800;
    }
    .online-badge.active {
        background: rgba(16,185,129,.1); color: #065f46;
        border: 1px solid rgba(16,185,129,.25);
    }
    .online-badge.active::before {
        content: ''; width: 6px; height: 6px; border-radius: 50%;
        background: #10b981;
        box-shadow: 0 0 0 0 rgba(16,185,129,.5);
        animation: livePulse 1.8s infinite;
    }
    .online-badge.offline {
        background: rgba(100,116,139,.09); color: #475569;
        border: 1px solid rgba(100,116,139,.2);
    }
    .dummy-grid { display: grid; gap: 1rem; grid-template-columns: 1.1fr .9fr; }
    .dummy-card {
        border: 1px solid #dce8f0;
        border-radius: 14px;
        background: #fff;
        box-shadow: 0 4px 24px rgba(22, 37, 52, .08);
        overflow: hidden;
        transition: box-shadow .2s;
    }
    .dummy-card:hover { box-shadow: 0 12px 36px rgba(22,37,52,.13); }
    .dummy-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .7rem;
        padding: .88rem 1.1rem;
        background: linear-gradient(135deg, #1b3059, #1f4ed8, #0ea5e9);
        color: #fff;
        position: relative; overflow: hidden;
    }
    .dummy-head::after {
        content: '';
        position: absolute; left: 0; right: 0;
        height: 1px; background: rgba(255,255,255,.12);
        animation: scanLine 3.5s linear infinite;
    }
    .dummy-head h6 { margin: 0; font-size: .83rem; font-weight: 800; position:relative;z-index:1; }
    .dummy-body { padding: 1rem 1.1rem; }
    .seg-wrap { display: grid; grid-template-columns: repeat(3, 1fr); gap: .6rem; margin-bottom: .9rem; }
    .seg {
        border-radius: 8px;
        padding: .75rem .7rem;
        color: #fff;
        min-height: 84px;
    }
    .seg h4 { margin: 0; font-size: 1.2rem; font-weight: 800; }
    .seg p { margin: .2rem 0 0; font-size: .72rem; opacity: .95; }
    .seg.good { background: linear-gradient(135deg, #07a96f, #21d596); }
    .seg.mid { background: linear-gradient(135deg, #d08907, #f5b52f); }
    .seg.low { background: linear-gradient(135deg, #d34747, #f06e6e); }
    .leader-row {
        display: grid;
        grid-template-columns: minmax(140px, 1fr) 76px 56px;
        align-items: center;
        gap: .5rem;
        margin-bottom: .55rem;
    }
    .leader-name { font-size: .8rem; font-weight: 700; color: #1f3548; }
    .leader-bar {
        height: 7px;
        background: #e8eef4;
        border-radius: 999px;
        overflow: hidden;
    }
    .leader-bar > span {
        display: block;
        height: 100%;
        border-radius: 999px;
        background: linear-gradient(90deg, #2b8db2, #30bfd6);
    }
    .leader-val { font-size: .73rem; font-weight: 800; color: #345267; text-align: right; }
    .dummy-sales-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .7rem;
        margin-top: .75rem;
    }
    .guide-card{
        border:1px solid #dce8f0;
        border-radius:14px;
        background:#fff;
        box-shadow:0 4px 24px rgba(22,37,52,.08);
        overflow:hidden;
    }
    .guide-head{
        padding:.9rem 1.1rem;
        background:linear-gradient(135deg,#1b3059,#1f4ed8,#0ea5e9);
        color:#fff;
        font-size:.9rem;
        font-weight:800;
    }
    .guide-body{padding:1rem 1.1rem}
    .guide-grid{
        display:grid;
        grid-template-columns:repeat(2,minmax(0,1fr));
        gap:.8rem;
    }
    .guide-item{
        border:1px solid #e6eef5;
        border-radius:10px;
        padding:.75rem .8rem;
        background:#f9fcff;
    }
    .guide-item h6{margin:0 0 .35rem;color:#163047;font-size:.82rem;font-weight:800}
    .guide-item ol{margin:0;padding-left:1.05rem}
    .guide-item li{font-size:.77rem;color:#4a647a;line-height:1.5;margin-bottom:.22rem}
    .dummy-sales-card {
        border: 1px solid #d8e4ef;
        border-radius: 10px;
        background: linear-gradient(135deg, #ffffff, #f7fbff);
        padding: .65rem;
    }
    .dummy-sales-top {
        display: flex;
        align-items: center;
        gap: .55rem;
        margin-bottom: .55rem;
    }
    .dummy-sales-photo {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid rgba(31, 78, 216, .22);
    }
    .dummy-sales-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .76rem;
        font-weight: 800;
        color: #fff;
        background: linear-gradient(135deg, #1f4ed8, #0ea5e9);
    }
    .dummy-sales-name {
        margin: 0;
        color: #173047;
        font-size: .78rem;
        font-weight: 800;
        line-height: 1.15;
    }
    .dummy-sales-role {
        margin: .14rem 0 0;
        color: #688095;
        font-size: .68rem;
        font-weight: 700;
    }
    .dummy-kpi-line {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: .24rem;
        color: #244359;
        font-size: .7rem;
        font-weight: 700;
    }
    .dummy-kpi-line strong {
        font-size: .74rem;
        color: #16344d;
    }
    .dummy-progress {
        height: 7px;
        border-radius: 999px;
        background: #e4edf6;
        overflow: hidden;
        margin-bottom: .35rem;
    }
    .dummy-progress > span {
        display: block; height: 100%;
        border-radius: 999px;
        background: linear-gradient(90deg, #1f4ed8, #0ea5e9);
        animation: barFill .9s ease both;
    }
    .dummy-stars {
        color: #d4a84f;
        font-size: .71rem;
        letter-spacing: .03em;
    }
    .dummy-stars .off { color: #d5dee7; }
    .risk-item {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: .7rem;
        padding: .55rem 0;
        border-bottom: 1px dashed #dde8f0;
    }
    .risk-item:last-child { border-bottom: 0; padding-bottom: 0; }
    .risk-name { margin: 0; font-size: .79rem; color: #22384a; font-weight: 700; }
    .risk-sub { margin: .1rem 0 0; font-size: .72rem; color: #73889b; }
    .pill-soft {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: .14rem .48rem;
        font-size: .66rem;
        font-weight: 800;
        white-space: nowrap;
    }
    .pill-red { background: rgba(216,95,95,.14); color: #a53f3f; }
    .pill-amber { background: rgba(221,160,45,.14); color: #9a6a10; }
    .pill-green { background: rgba(36,181,136,.15); color: #0f7859; }
    .insight-list { margin: 0; padding-left: 1rem; color: #5f7487; font-size: .78rem; }
    .insight-list li { margin-bottom: .4rem; }
    .graph-grid {
        display: grid;
        grid-template-columns: 1.35fr .85fr;
        gap: 1rem;
    }
    .graph-card {
        border: 1px solid #dce8f0;
        border-radius: 14px;
        background: #fff;
        box-shadow: 0 4px 24px rgba(22, 37, 52, .08);
        overflow: hidden;
        transition: box-shadow .2s;
    }
    .graph-card:hover { box-shadow: 0 12px 36px rgba(22,37,52,.13); }
    .graph-head {
        padding: .88rem 1.1rem;
        background: linear-gradient(135deg, #1a315a, #1f4ed8, #0ea5e9);
        color: #fff;
        font-size: .82rem; font-weight: 800;
        display: flex; align-items: center; justify-content: space-between;
        position: relative; overflow: hidden;
    }
    .graph-head::after {
        content: '';
        position: absolute; left: 0; right: 0;
        height: 1px; background: rgba(255,255,255,.12);
        animation: scanLine 4s linear infinite;
    }
    .graph-body { padding: 1rem; }
    .mini-kpi-wrap {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: .6rem;
        margin-top: .8rem;
    }
    .mini-kpi {
        border: 1px solid #d8e5f0;
        border-radius: 9px;
        background: linear-gradient(135deg,#f7fbff,#eef6ff);
        padding: .55rem .6rem;
        transition: transform .15s;
    }
    .mini-kpi:hover { transform: scale(1.03); }
    .mini-kpi .v {
        color: #12314b;
        font-size: 1rem;
        font-weight: 800;
        line-height: 1;
        margin: 0;
    }
    .mini-kpi .l {
        margin-top: .2rem;
        color: #60788e;
        font-size: .68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .04em;
    }
    .funnel-list {
        list-style: none;
        margin: 0;
        padding: 0;
    }
    .funnel-list li {
        margin-bottom: .62rem;
    }
    .funnel-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: .22rem;
        color: #1b3348;
        font-size: .76rem;
        font-weight: 700;
    }
    .funnel-bar {
        height: 9px;
        border-radius: 999px;
        background: #e5eff7;
        overflow: hidden;
    }
    .funnel-bar > span {
        display: block; height: 100%; border-radius: 999px;
        animation: barFill 1s ease both;
    }
    @@media (max-width: 1199.98px) {
        .kpi-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
        .quick-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }
    @@media (max-width: 991.98px) {
        .dummy-grid { grid-template-columns: 1fr; }
        .seg-wrap { grid-template-columns: 1fr; }
        .dummy-sales-grid { grid-template-columns: 1fr; }
        .graph-grid { grid-template-columns: 1fr; }
        .mini-kpi-wrap { grid-template-columns: 1fr; }
        .kpi-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
        .quick-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        #dashMap { height: 300px; }
    }

    @@media (max-width: 991.98px) {
        .dash-hero {
            align-items: flex-start;
            flex-direction: column;
        }
        .panel-head h6 {
            font-size: .78rem;
        }
        .panel-meta {
            font-size: .66rem;
            padding: .24rem .48rem;
        }
        .visit-name,
        .visit-cp {
            max-width: 110px;
        }
        .sales-name {
            font-size: .78rem;
        }
        .sales-job {
            font-size: .68rem;
        }
    }
    @@media (min-width: 1600px) {
        .dash-shell {
            max-width: 1700px;
            margin-left: auto;
            margin-right: auto;
        }
        #dashMap { height: 410px; }
    }
    @@media (max-width: 576px) {
        .dash-shell { margin-bottom: 1rem; }
        .dash-hero {
            padding: .95rem .9rem;
            border-radius: 10px;
        }
        .dash-title {
            font-size: .95rem;
        }
        .dash-sub {
            font-size: .74rem;
        }
        .dash-date-chip {
            width: 100%;
            justify-content: center;
            font-size: .7rem;
        }
        .kpi-card .card-body {
            padding: .85rem .85rem;
        }
        .kpi-value {
            font-size: 1.26rem;
        }
        .kpi-grid {
            grid-template-columns: 1fr;
        }
        .quick-grid { grid-template-columns: 1fr; }
        .dummy-body,
        .prem-card-body {
            padding: .85rem .85rem;
        }
    }
</style>
}

<div class="dash-shell">
    <div class="dash-hero mb-4">
        <div class="hero-orbit"></div>
        <div style="position:relative;z-index:1;">
            <p class="dash-title"><i class="fas fa-chart-line mr-2 text-primary"></i>Ringkasan Operasional Sales</p>
            <p class="dash-sub">Pantau progres kunjungan, checkpoint aktif, dan posisi sales real-time dari satu halaman.</p>
        </div>
        <div class="hero-right">
            <div class="hero-stat anim-7">
                <span class="hero-stat-val" data-count="@Model.TodayArrived">0</span>
                <span class="hero-stat-lbl">Tiba</span>
            </div>
            <div class="hero-stat anim-8">
                <span class="hero-stat-val" data-count="@Model.TodayPending">0</span>
                <span class="hero-stat-lbl">Pending</span>
            </div>
            <div class="dash-date-chip">
                <i class="fas fa-calendar-alt"></i>
                @DateTime.Today.ToString("dddd, dd MMMM yyyy")
            </div>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="kpi-item anim-1">
            <div class="card kpi-card kpi-blue h-100">
                <div class="card-body">
                    <div class="kpi-top">
                        <p class="kpi-label">User Aktif</p>
                        <span class="kpi-icon"><i class="fas fa-users"></i></span>
                    </div>
                    <p class="kpi-value" data-count="@Model.TotalUsers">0</p>
                    <div class="kpi-note">Akun dengan status aktif</div>
                </div>
            </div>
        </div>
        <div class="kpi-item anim-2">
            <div class="card kpi-card kpi-cyan h-100">
                <div class="card-body">
                    <div class="kpi-top">
                        <p class="kpi-label">Checkpoint</p>
                        <span class="kpi-icon"><i class="fas fa-map-pin"></i></span>
                    </div>
                    <p class="kpi-value" data-count="@Model.TotalCheckpoints">0</p>
                    <div class="kpi-note">Lokasi kunjungan aktif</div>
                </div>
            </div>
        </div>
        <div class="kpi-item anim-3">
            <div class="card kpi-card kpi-purple h-100">
                <div class="card-body">
                    <div class="kpi-top">
                        <p class="kpi-label">Kunjungan Hari Ini</p>
                        <span class="kpi-icon"><i class="fas fa-route"></i></span>
                    </div>
                    <p class="kpi-value" data-count="@Model.TodayVisits">0</p>
                    <div class="kpi-note">Total visit terjadwal</div>
                </div>
            </div>
        </div>
        <div class="kpi-item anim-4">
            <div class="card kpi-card kpi-green h-100">
                <div class="card-body">
                    <div class="kpi-top">
                        <p class="kpi-label">Sudah Tiba</p>
                        <span class="kpi-icon"><i class="fas fa-check-circle"></i></span>
                    </div>
                    <p class="kpi-value" data-count="@Model.TodayArrived">0</p>
                    <div class="kpi-note">Visit dengan status tiba</div>
                </div>
            </div>
        </div>
        <div class="kpi-item anim-5">
            <div class="card kpi-card kpi-amber h-100">
                <div class="card-body">
                    <div class="kpi-top">
                        <p class="kpi-label">Pending</p>
                        <span class="kpi-icon"><i class="fas fa-clock"></i></span>
                    </div>
                    <p class="kpi-value" data-count="@Model.TodayPending">0</p>
                    <div class="kpi-note">Visit belum dieksekusi</div>
                </div>
            </div>
        </div>
        <div class="kpi-item anim-6">
            <div class="card kpi-card kpi-navy h-100">
                <div class="card-body">
                    <div class="kpi-top">
                        <p class="kpi-label">Sales Aktif (30m)</p>
                        <span class="kpi-icon"><i class="fas fa-user-check"></i></span>
                    </div>
                    <p class="kpi-value">@Model.SalesActiveToday/@Model.SalesTotal</p>
                    <div class="kpi-note">Sales online vs total sales</div>
                </div>
            </div>
        </div>
        <div class="kpi-item anim-7">
            <div class="card kpi-card kpi-purple h-100">
                <div class="card-body">
                    <div class="kpi-top">
                        <p class="kpi-label">Rata Capaian</p>
                        <span class="kpi-icon"><i class="fas fa-bullseye"></i></span>
                    </div>
                    <p class="kpi-value">@Model.AvgAchievementPercent.ToString("0.#")%</p>
                    <div class="kpi-note">Completion rate kunjungan: @Model.VisitCompletionRate.ToString("0.#")%</div>
                </div>
            </div>
        </div>
        <div class="kpi-item anim-8">
            <div class="card kpi-card kpi-blue h-100">
                <div class="card-body">
                    <div class="kpi-top">
                        <p class="kpi-label">Pending Approval</p>
                        <span class="kpi-icon"><i class="fas fa-bell"></i></span>
                    </div>
                    <p class="kpi-value" data-count="@Model.TotalPendingApprovals">0</p>
                    <div class="kpi-note">Toko @Model.PendingStoreSubmissions · Izin @Model.PendingLeaveApprovals · Lembur @Model.PendingOvertimeApprovals</div>
                </div>
            </div>
        </div>
    </div>
    <div class="quick-grid anim-8">
        <a class="quick-link" href="/Approval/Index"><i class="fas fa-tasks text-primary"></i>Proses Approval</a>
        <a class="quick-link" href="/SalesSchedule/Index"><i class="fas fa-calendar-check text-info"></i>Atur Jadwal Kunjungan</a>
        <a class="quick-link" href="/SalesTracking/History"><i class="fas fa-file-export text-success"></i>Laporan Kunjungan</a>
        <a class="quick-link" href="/Audit/Index"><i class="fas fa-clipboard-list text-warning"></i>Audit Aktivitas</a>
    </div>

    <div class="row">
        <div class="col-lg-7 mb-4">
            <div class="card shadow panel-card h-100">
                <div class="card-header panel-head d-flex align-items-center justify-content-between">
                    <h6><i class="fas fa-satellite-dish mr-2"></i>Live Sales - Posisi 30 Menit Terakhir</h6>
                    <div class="d-flex align-items-center gap-2" style="gap:.6rem;">
                        <span class="live-indicator"><span class="live-dot"></span></span>
                        <span class="panel-meta"><i class="fas fa-broadcast-tower"></i><span id="onlineCount">@Model.SalesOnline.Count online</span></span>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div id="dashMap"></div>
                    <div id="mapEmpty" class="mini-empty d-none">Belum ada data GPS sales dalam 30 menit terakhir.</div>
                </div>
            </div>
        </div>

        <div class="col-lg-5 mb-4">
            <div class="card shadow panel-card h-100">
                <div class="card-header panel-head">
                    <h6><i class="fas fa-history mr-2"></i>Aktivitas Kunjungan Hari Ini</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0 visit-table">
                            <thead class="thead-light">
                                <tr>
                                    <th>Sales</th>
                                    <th>Checkpoint</th>
                                    <th>Status</th>
                                    <th>Waktu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.RecentVisits.Any())
                                {
                                    <tr><td colspan="4" class="text-center text-muted py-4">Belum ada kunjungan hari ini</td></tr>
                                }
                                @foreach (var v in Model.RecentVisits)
                                {
                                    var statusClass = v.Status switch
                                    {
                                        "arrived" => "status-arrived",
                                        "completed" => "status-completed",
                                        "skipped" => "status-skipped",
                                        _ => "status-pending"
                                    };
                                    var statusText = v.Status switch
                                    {
                                        "arrived" => "Tiba",
                                        "completed" => "Selesai",
                                        "skipped" => "Dilewati",
                                        _ => "Pending"
                                    };

                                    <tr>
                                        <td class="visit-name" title="@v.SalesName">@v.SalesName</td>
                                        <td class="visit-cp" title="@v.CheckpointName">@v.CheckpointName</td>
                                        <td><span class="status-pill @statusClass">@statusText</span></td>
                                        <td class="small text-muted">@(v.ArrivedAt.HasValue ? v.ArrivedAt.Value.ToLocalTime().ToString("HH:mm") : "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12 mb-4">
            <div class="card shadow sales-ana-card">
                <div class="card-header panel-head d-flex align-items-center justify-content-between">
                    <h6><i class="fas fa-user-tie mr-2"></i>Analitik Sales Harian</h6>
                    <div class="d-flex align-items-center" style="gap:.6rem;">
                        <span class="live-indicator"><span class="live-dot"></span></span>
                        <span class="panel-meta"><i class="fas fa-clipboard-check"></i>Target Kunjungan</span>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="thead-light">
                                <tr>
                                    <th>Sales</th>
                                    <th>Aktif</th>
                                    <th>Target</th>
                                    <th>Realisasi</th>
                                    <th style="min-width:140px;">Capaian</th>
                                    <th>Rating</th>
                                    <th>Terakhir Online</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.SalesPerformances.Any())
                                {
                                    <tr><td colspan="7" class="text-center text-muted py-4">Belum ada data sales.</td></tr>
                                }
                                @foreach (var s in Model.SalesPerformances)
                                {
                                    var initials = string.Join("", s.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpper();
                                    var barClass = s.AchievementPercent >= 80 ? "" : (s.AchievementPercent >= 40 ? "warn" : "danger");
                                    var barWidth = Math.Min(100, (int)s.AchievementPercent);
                                    <tr>
                                        <td>
                                            <div class="sales-row">
                                                @if (!string.IsNullOrWhiteSpace(s.PhotoPath))
                                                {
                                                    <img src="@s.PhotoPath" alt="@System.Net.WebUtility.HtmlEncode(s.FullName)" class="sales-photo" />
                                                }
                                                else
                                                {
                                                    <span class="sales-photo-fallback">@initials</span>
                                                }
                                                <div>
                                                    <p class="sales-name">@s.FullName</p>
                                                    <p class="sales-job">@s.JobTitle</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            @if (s.IsActiveToday)
                                            {
                                                <span class="online-badge active">Online</span>
                                            }
                                            else
                                            {
                                                <span class="online-badge offline">Offline</span>
                                            }
                                        </td>
                                        <td><strong>@s.DailyTarget</strong></td>
                                        <td><strong>@s.CompletedVisits</strong></td>
                                        <td>
                                            <div class="perf-bar-wrap">
                                                <div class="perf-bar @barClass"><span style="width:@barWidth%"></span></div>
                                                <span class="achv-text">@s.AchievementPercent.ToString("0.#")%</span>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="star-wrap">
                                                @for (var i = 1; i <= 5; i++)
                                                {
                                                    if (i <= s.StarRating)
                                                    {
                                                        <i class="fas fa-star"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="fas fa-star star-muted"></i>
                                                    }
                                                }
                                            </span>
                                        </td>
                                        <td class="small text-muted">@(s.LastSeen.HasValue ? s.LastSeen.Value.ToLocalTime().ToString("HH:mm") : "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="dummy-grid mb-4">
        <div class="dummy-card">
            <div class="dummy-head">
                <h6><i class="fas fa-vial mr-2"></i>Dummy - Simulasi Pencapaian Harian</h6>
                <span class="panel-meta"><i class="fas fa-lightbulb"></i>Preview UI</span>
            </div>
            <div class="dummy-body">
                <div class="seg-wrap">
                    <div class="seg good">
                        <h4>16</h4>
                        <p>Karyawan Baik<br />Capaian 90-100%</p>
                    </div>
                    <div class="seg mid">
                        <h4>9</h4>
                        <p>Karyawan Cukup<br />Capaian 70-89%</p>
                    </div>
                    <div class="seg low">
                        <h4>5</h4>
                        <p>Karyawan Kurang<br />Capaian &lt;70%</p>
                    </div>
                </div>
                <div class="dummy-sales-grid">
                    <div class="dummy-sales-card">
                        <div class="dummy-sales-top">
                            <span class="dummy-sales-avatar">DA</span>
                            <div>
                                <p class="dummy-sales-name">Dina Aulia</p>
                                <p class="dummy-sales-role">Sales Executive</p>
                            </div>
                        </div>
                        <div class="dummy-kpi-line"><span>Target</span><strong>12 toko</strong></div>
                        <div class="dummy-kpi-line"><span>Pencapaian</span><strong>12 toko (100%)</strong></div>
                        <div class="dummy-progress"><span style="width:100%"></span></div>
                        <div class="dummy-stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                    </div>
                    <div class="dummy-sales-card">
                        <div class="dummy-sales-top">
                            <span class="dummy-sales-avatar">RP</span>
                            <div>
                                <p class="dummy-sales-name">Rizky Pratama</p>
                                <p class="dummy-sales-role">Area Sales</p>
                            </div>
                        </div>
                        <div class="dummy-kpi-line"><span>Target</span><strong>13 toko</strong></div>
                        <div class="dummy-kpi-line"><span>Pencapaian</span><strong>12 toko (92%)</strong></div>
                        <div class="dummy-progress"><span style="width:92%"></span></div>
                        <div class="dummy-stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star off"></i></div>
                    </div>
                    <div class="dummy-sales-card">
                        <div class="dummy-sales-top">
                            <span class="dummy-sales-avatar">NP</span>
                            <div>
                                <p class="dummy-sales-name">Nabila Putri</p>
                                <p class="dummy-sales-role">Merchandiser</p>
                            </div>
                        </div>
                        <div class="dummy-kpi-line"><span>Target</span><strong>19 toko</strong></div>
                        <div class="dummy-kpi-line"><span>Pencapaian</span><strong>16 toko (84%)</strong></div>
                        <div class="dummy-progress"><span style="width:84%"></span></div>
                        <div class="dummy-stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star off"></i><i class="fas fa-star off"></i></div>
                    </div>
                    <div class="dummy-sales-card">
                        <div class="dummy-sales-top">
                            <span class="dummy-sales-avatar">FA</span>
                            <div>
                                <p class="dummy-sales-name">Fahmi Akbar</p>
                                <p class="dummy-sales-role">Sales Representative</p>
                            </div>
                        </div>
                        <div class="dummy-kpi-line"><span>Target</span><strong>22 toko</strong></div>
                        <div class="dummy-kpi-line"><span>Pencapaian</span><strong>15 toko (68%)</strong></div>
                        <div class="dummy-progress"><span style="width:68%"></span></div>
                        <div class="dummy-stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star off"></i><i class="fas fa-star off"></i><i class="fas fa-star off"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="dummy-card">
            <div class="dummy-head">
                <h6><i class="fas fa-shield-alt mr-2"></i>Dummy - Risiko & Insight</h6>
                <span class="panel-meta"><i class="fas fa-chart-pie"></i>Analitik Lainnya</span>
            </div>
            <div class="dummy-body">
                <div class="risk-item">
                    <div>
                        <p class="risk-name">KPI Coverage Wilayah Timur</p>
                        <p class="risk-sub">2 sales melewati 3 toko wajib hari ini.</p>
                    </div>
                    <span class="pill-soft pill-red">High Risk</span>
                </div>
