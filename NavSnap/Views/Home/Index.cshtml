@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
    /* ── countUp animation ── */
    function countUp(el) {
        var target = parseFloat(el.dataset.count);
        if (isNaN(target)) return;
        var isInt = Number.isInteger(target);
        var duration = 900;
        var start = null;
        function step(ts) {
            if (!start) start = ts;
            var progress = Math.min((ts - start) / duration, 1);
            var ease = 1 - Math.pow(1 - progress, 3);
            var val = target * ease;
            el.textContent = isInt ? Math.round(val) : val.toFixed(1);
            if (progress < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
    }
    document.querySelectorAll('[data-count]').forEach(function(el) { countUp(el); });

    /* ── live clock update ── */
    var clockEl = document.getElementById('liveClock');
    function updateClock() {
        if (!clockEl) return;
        var now = new Date();
        var h = String(now.getHours()).padStart(2,'0');
        var m = String(now.getMinutes()).padStart(2,'0');
        var s = String(now.getSeconds()).padStart(2,'0');
        clockEl.textContent = h + ':' + m + ':' + s;
    }
    setInterval(updateClock, 1000);
    updateClock();

    /* ── IntersectionObserver for table rows ── */
    var io = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
            if (e.isIntersecting) {
                e.target.style.animation = 'slideUp .4s ease both';
                io.unobserve(e.target);
            }
        });
    }, { threshold: 0.1 });
    document.querySelectorAll('.visit-table tbody tr').forEach(function(tr, i) {
        tr.style.animationDelay = (i * 0.06) + 's';
        io.observe(tr);
    });

    /* ── map ── */
    var salesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SalesOnline.Select(s => new {
        s.FullName, s.LastLatitude, s.LastLongitude,
        lastSeen = s.LastSeen?.ToString("HH:mm") ?? "-"
    })));

    var map = L.map('dashMap', { zoomControl: true }).setView([-2.5, 117.5], 5);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors',
        maxZoom: 18
    }).addTo(map);

    var salesIcon = L.divIcon({
        html: '<div style="background:linear-gradient(135deg,#0f6b8f,#2bbbd8);color:white;border-radius:50%;width:32px;height:32px;display:flex;align-items:center;justify-content:center;font-size:12px;box-shadow:0 5px 14px rgba(15,107,143,0.45);border:2px solid rgba(255,255,255,0.95);"><i class="fas fa-user"></i></div>',
        className: '',
        iconSize: [32, 32],
        iconAnchor: [16, 16]
    });

    var hasMarker = false;
    salesData.forEach(function (s) {
        if (s.LastLatitude && s.LastLongitude) {
            hasMarker = true;
            L.marker([s.LastLatitude, s.LastLongitude], { icon: salesIcon })
                .addTo(map)
                .bindPopup('<strong>' + s.FullName + '</strong><br>Terakhir: ' + s.lastSeen);
        }
    });

    if (hasMarker) {
        var first = salesData.find(function (s) { return s.LastLatitude && s.LastLongitude; });
        if (first) map.setView([first.LastLatitude, first.LastLongitude], 11);
    } else {
        document.getElementById('dashMap').classList.add('d-none');
        document.getElementById('mapEmpty').classList.remove('d-none');
    }

    /* ── Chart.js trend ── */
    var trendCtx = document.getElementById('dummyTrendChart');
    if (trendCtx) {
        new Chart(trendCtx, {
            type: 'line',
            data: {
                labels: ['Sen', 'Sel', 'Rab', 'Kam', 'Jum', 'Sab', 'Min'],
                datasets: [{
                    label: 'Kepatuhan Target (%)',
                    data: [72, 76, 80, 85, 91, 88, 94],
                    borderColor: '#3f5efb',
                    backgroundColor: 'rgba(63,94,251,.15)',
                    fill: true,
                    tension: .36,
                    borderWidth: 2.6,
                    pointRadius: 3.2,
                    pointBackgroundColor: '#0cc6ff'
                }, {
                    label: 'Kunjungan Selesai',
                    data: [38, 44, 49, 56, 63, 59, 68],
                    borderColor: '#08b87a',
                    backgroundColor: 'rgba(8,184,122,.08)',
                    tension: .35,
                    borderWidth: 2.3,
                    pointRadius: 2.8
                }]
            },
            options: {
                animation: { duration: 1200, easing: 'easeOutQuart' },
                responsive: true,
                maintainAspectRatio: false,
                interaction: { intersect: false, mode: 'nearest' },
                plugins: {
                    legend: { labels: { boxWidth: 10, usePointStyle: true, pointStyle: 'circle' } },
                    tooltip: { enabled: true }
                },
                scales: {
                    x: { grid: { display: false } },
                    y: { beginAtZero: true, max: 100, ticks: { callback: (v) => v + '%' }, grid: { color: 'rgba(18,49,75,.08)' } }
                }
            }
        });
    }

    /* ── Chart.js doughnut ── */
    var mixCtx = document.getElementById('dummyMixChart');
    if (mixCtx) {
        new Chart(mixCtx, {
            type: 'doughnut',
            data: {
                labels: ['On Target', 'Late Visit', 'Not Visited', 'Reschedule'],
                datasets: [{
                    data: [58, 20, 13, 9],
                    backgroundColor: ['#08b87a', '#f4ad21', '#ef4f79', '#3f5efb'],
                    borderWidth: 0
                }]
            },
            options: {
                animation: { duration: 1000, easing: 'easeOutBounce' },
                responsive: true,
                maintainAspectRatio: false,
                cutout: '68%',
                plugins: {
                    legend: { position: 'bottom', labels: { boxWidth: 10, usePointStyle: true, pointStyle: 'circle' } }
                }
            }
        });
    }
</script>
}
